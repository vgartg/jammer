<div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
  <% items.each do |item| %>
    <a href="<%= game_profile_path(item) %>" class="group block rounded-2xl overflow-hidden bg-gray-800 border border-gray-700/60 hover:border-gray-500/80 transition-all hover:shadow-xl hover:shadow-black/40">
      <div class="aspect-video relative overflow-hidden bg-gray-700">
        <% if item && item.cover.attached? %>
          <%= image_tag url_for(item.cover), alt: item.name,
                class: "w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" %>
        <% else %>
          <%= image_tag 'empty-avatar.jpg', alt: item.name,
                class: "w-full h-full object-cover" %>
        <% end %>
        <div class="absolute inset-0 bg-gradient-to-t from-gray-900/60 to-transparent"></div>
        <div class="absolute top-2 right-2 flex items-center gap-1 bg-gray-900/70 backdrop-blur-sm rounded-full px-2 py-1">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 text-yellow-400" viewBox="0 0 20 20" fill="currentColor">
            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
          </svg>
          <span class="text-xs font-semibold text-white"><%= item.overall_rating.to_f %></span>
        </div>
      </div>

      <div class="p-4">
        <h3 class="font-semibold text-white text-sm truncate group-hover:text-indigo-400 transition-colors">
          <%= item.name %>
        </h3>
        <% if item.description.present? %>
          <p class="mt-1 text-xs text-gray-400 line-clamp-2"><%= item.description %></p>
        <% end %>

        <% if item.tags.any? %>
          <div class="mt-2 flex flex-wrap gap-1">
            <% item.tags.first(3).each do |tag| %>
              <span class="bg-gray-700 px-2 py-0.5 rounded-full text-xs text-gray-300"><%= tag.name %></span>
            <% end %>
          </div>
        <% end %>

        <div class="mt-3 flex items-center gap-2">
          <% if item.author.present? %>
            <% if item.author.avatar.attached? %>
              <%= image_tag url_for(item.author.avatar), alt: item.author.name,
                    class: "h-5 w-5 rounded-full object-cover" %>
            <% else %>
              <%= image_tag 'empty-avatar.jpg', alt: item.author.name,
                    class: "h-5 w-5 rounded-full object-cover" %>
            <% end %>
            <span class="text-xs text-gray-400 truncate"><%= item.author.name %></span>
          <% else %>
            <span class="text-xs text-gray-600"><%= t 'games.showcase.no_author' %></span>
          <% end %>
        </div>
      </div>
    </a>
  <% end %>
</div>
