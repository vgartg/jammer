<div class="grid grid-cols-1 gap-y-10 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-x-6">
  <% items.each do |item| %>
    <div class="bg-white shadow-md rounded-lg overflow-hidden transition-transform transform hover:scale-105">
      <div class="relative">
        <a href="/games/<%= item.id %>">
          <% if item && item.cover.attached? %>
            <%= image_tag url_for(item.cover), alt: item.name,
                          class: "h-56 w-full object-cover object-center" %>
          <% else %>
            <div class="aspect-w-16 aspect-h-9 bg-gray-200">
              <%= image_tag 'empty-avatar.jpg', alt: item.name, class: "object-cover object-center" %>
            </div>
          <% end %>
        </a>
        <div class="absolute top-2 right-2 bg-white rounded-full px-2 py-1 shadow flex items-center space-x-1">
          <span class="text-sm font-bold text-gray-800"><%= item.overall_rating.to_f %></span>
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-yellow-500" viewBox="0 0 20 20" fill="currentColor">
            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
          </svg>
        </div>
      </div>

      <div class="p-4">
        <h3 class="text-lg font-medium text-gray-800 truncate">
          <a href="/games/<%= item.id %>"><%= item.name %></a>
        </h3>
        <p class="mt-1 text-sm text-gray-500 line-clamp-2"><%= item.description %></p>

        <div class="mt-2 text-gray-500 flex flex-wrap gap-2">
          <% item.tags.each do |tag| %>
            <span class="bg-gray-200 px-3 py-1 rounded-full text-sm font-medium text-gray-700"><%= tag.name %></span>
          <% end %>
        </div>
        <% if item.author.present? %>
          <a class="mt-2 block text-gray-700 text-sm" href="<%= user_profile_path(item.author) %>">
            <%= item.author.name %>
          </a>
        <% else %>
          <p class="mt-2 text-gray-600 text-sm"><%= t 'games.showcase.no_author' %></p>
        <% end %>
      </div>
    </div>
  <% end %>
</div>
