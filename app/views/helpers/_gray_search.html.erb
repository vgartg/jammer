<div class="sticky top-0 z-40 flex h-16 shrink-0 items-center gap-x-6 border-b border-white/5 bg-gray-900
 px-4 shadow-sm sm:px-6 lg:px-8">
  <button type="button" class="-m-2.5 p-2.5 text-gray-700 lg:hidden"
          data-action="click->dashboard#openMobileMenu">
    <svg class="h-6 w-6" fill="none"
         viewBox="0 0 24 24"
         stroke-width="1.5"
         stroke="currentColor"
         aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round"
            d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"/>
    </svg>
  </button>

  <div class="h-6 w-px bg-gray-900/10 lg:hidden" aria-hidden="true"></div>

  <div class="flex flex-1 gap-x-4 self-stretch lg:gap-x-6">
    <div class="flex flex-1"></div>
    <div class="flex items-center gap-x-4 lg:gap-x-6">
      <% unread_count = notifications ? notifications.count { |n| !n.read } : 0 %>
      <div class="relative" data-controller="notifications"
           data-notifications-mark-as-read-url-value="<%= notifications_mark_as_read_path %>">
        <button type="button" class="-m-2.5 p-2.5 text-gray-400 hover:text-gray-500 relative"
                data-action="click->notifications#toggleNotificationsMenu">
          <svg class="h-6 w-6" fill="none"
               viewBox="0 0 24 24"
               stroke-width="1.5"
               stroke="currentColor"
               aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round"
                  d="M14.857 17.082a23.848 23.848 0 005.454-1.31A8.967 8.967 0 0118 9.75v-.7V9A6 6 0 006 9v.75a8.967 8.967 0 01-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 01-5.714 0m5.714 0a3 3 0 11-5.714 0"/>
          </svg>
          <% if unread_count > 0 %>
            <span data-notifications-target="badge"
                  class="absolute top-0 right-0 inline-block h-3 w-3 rounded-full bg-red-500
                   text-white text-xs flex items-center justify-center">
              <%= unread_count %>
            </span>
          <% end %>
        </button>
        <div class="hidden absolute min-w-72 w-72 sm:min-w-96 sm:w-96 right-0 z-10 mt-2.5 origin-top-right
        rounded-2xl bg-gray-900 border border-gray-700/60 shadow-2xl
        focus:outline-none overflow-hidden"
             role="menu" aria-labelledby="notifications-menu-button"
             tabindex="-1"
             id="dashboard_notifications_menu"
             data-notifications-target="notificationsMenu"
             style="max-height: 70vh; overflow-y: auto">

          <% if notifications&.any? %>
            <div class="p-2 space-y-1">
              <% notifications.first(8).each do |notification| %>
                <% next if notification.notifiable.nil? && notification.actor.nil? %>

                <div class="flex items-start gap-3 rounded-xl p-3 border <%= notification.read ? 'border-gray-700/50' : 'border-indigo-700/40' %> bg-gray-800 hover:border-gray-600/80 transition-all group">

                  <%# Аватар %>
                  <div class="flex-shrink-0">
                    <% if notification.notifiable.is_a?(UserAchievement) %>
                      <div class="w-10 h-10 rounded-xl bg-yellow-900/30 border border-yellow-700/40 flex items-center justify-center">
                        <%= image_tag "achievements/#{notification.notifiable.achievement_key}.svg",
                                      alt: notification.notifiable.achievement_key,
                                      class: "w-6 h-6",
                                      onerror: "this.style.display='none'" rescue nil %>
                      </div>

                    <% elsif notification.notifiable.is_a?(AdminMessage) %>
                      <div class="w-10 h-10 rounded-xl bg-indigo-900/50 border border-indigo-700/40 flex items-center justify-center">
                        <svg class="w-5 h-5 text-indigo-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M7.5 8.25h9m-9 3H12m-9.75 1.51c0 1.6 1.123 2.994 2.707 3.227 1.129.166 2.27.293 3.423.379.35.026.67.21.865.501L12 21l2.755-4.133a1.14 1.14 0 01.865-.501 48.172 48.172 0 003.423-.379c1.584-.233 2.707-1.626 2.707-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0012 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018z"/>
                        </svg>
                      </div>

                    <% elsif notification.notifiable.is_a?(Game) %>
                      <a href="<%= game_profile_path(notification.notifiable) %>" class="block rounded-xl overflow-hidden w-10 h-10 bg-gray-700">
                        <% if notification.notifiable.cover.attached? %>
                          <%= image_tag url_for(notification.notifiable.cover), alt: notification.notifiable.name, class: "w-10 h-10 object-cover" %>
                        <% else %>
                          <%= image_tag 'empty-avatar.jpg', alt: notification.notifiable.name, class: "w-10 h-10 object-cover" %>
                        <% end %>
                      </a>

                    <% elsif notification.notifiable.is_a?(Jam) %>
                      <a href="<%= jam_profile_path(notification.notifiable) %>" class="block rounded-xl overflow-hidden w-10 h-10 bg-gray-700">
                        <% if notification.notifiable.cover.attached? %>
                          <%= image_tag url_for(notification.notifiable.cover), alt: notification.notifiable.name, class: "w-10 h-10 object-cover" %>
                        <% else %>
                          <%= image_tag 'empty-avatar.jpg', alt: notification.notifiable.name, class: "w-10 h-10 object-cover" %>
                        <% end %>
                      </a>

                    <% elsif notification.notifiable.is_a?(JamContributor) %>
                      <% jam = notification.notifiable.jam %>
                      <a href="<%= jam_profile_path(jam) %>" class="block rounded-xl overflow-hidden w-10 h-10 bg-gray-700">
                        <% if jam.cover.attached? %>
                          <%= image_tag url_for(jam.cover), alt: jam.name, class: "w-10 h-10 object-cover" %>
                        <% else %>
                          <%= image_tag 'empty-avatar.jpg', alt: jam.name, class: "w-10 h-10 object-cover" %>
                        <% end %>
                      </a>

                    <% elsif notification.actor %>
                      <a href="<%= user_profile_path(notification.actor) %>" class="block rounded-xl overflow-hidden w-10 h-10 bg-gray-700">
                        <% if notification.actor.avatar.attached? %>
                          <%= image_tag url_for(notification.actor.avatar), alt: notification.actor.name, class: "w-10 h-10 object-cover" %>
                        <% else %>
                          <%= image_tag 'empty-avatar.jpg', alt: notification.actor.name, class: "w-10 h-10 object-cover" %>
                        <% end %>
                      </a>
                    <% end %>
                  </div>

                  <%# Контент %>
                  <div class="flex-1 min-w-0">
                    <div class="flex items-start justify-between gap-1">
                      <div class="min-w-0 flex-1">
                        <% if notification.notifiable.is_a?(UserAchievement) %>
                          <% ach_key = notification.notifiable.achievement_key %>
                          <p class="text-xs font-semibold text-yellow-300 truncate">
                            <%= t("achievements.#{ach_key}.name", default: ach_key.humanize) %>
                          </p>
                          <p class="text-xs text-gray-400 mt-0.5"><%= notification_message(notification) %></p>

                        <% elsif notification.notifiable.is_a?(AdminMessage) %>
                          <p class="text-xs font-semibold text-indigo-300 truncate"><%= notification.notifiable.title %></p>
                          <% if notification.notifiable.body.present? %>
                            <p class="text-xs text-gray-400 mt-0.5 line-clamp-2"><%= notification.notifiable.body %></p>
                          <% end %>

                        <% elsif notification.notifiable.is_a?(Game) %>
                          <p class="text-xs font-medium text-white truncate">
                            <a href="<%= game_profile_path(notification.notifiable) %>" class="hover:text-indigo-400 transition-colors">
                              <%= notification.notifiable.name %>
                            </a>
                          </p>
                          <p class="text-xs text-gray-400 mt-0.5"><%= notification_message(notification) %></p>

                        <% elsif notification.notifiable.is_a?(Jam) || notification.notifiable.is_a?(JamContributor) %>
                          <% jam = notification.notifiable.is_a?(Jam) ? notification.notifiable : notification.notifiable.jam %>
                          <p class="text-xs font-medium text-white truncate">
                            <a href="<%= jam_profile_path(jam) %>" class="hover:text-indigo-400 transition-colors">
                              <%= jam.name %>
                            </a>
                          </p>
                          <p class="text-xs text-gray-400 mt-0.5"><%= notification_message(notification) %></p>

                        <% elsif notification.actor %>
                          <p class="text-xs font-medium text-white truncate">
                            <a href="<%= user_profile_path(notification.actor) %>" class="hover:text-indigo-400 transition-colors">
                              <%= notification.actor.name %>
                            </a>
                          </p>
                          <p class="text-xs text-gray-400 mt-0.5"><%= notification_message(notification) %></p>
                        <% end %>

                        <%# Кнопка принятия инвайта в жюри %>
                        <% if notification.action == "sent_jam_jury_invite" && notification.notifiable.is_a?(JamContributor) %>
                          <% contributor = notification.notifiable %>
                          <% jam = contributor.jam %>
                          <% if current_user && contributor.user_id == current_user.id && contributor.status == "pending" %>
                            <div class="mt-1.5">
                              <%= button_to t('helpers.gray_search.accept_jury_invite'),
                                            accept_contributor_invite_jam_path(jam, contributor_id: contributor.id),
                                            method: :patch,
                                            class: "rounded-lg bg-indigo-600 px-2.5 py-1 text-xs text-white hover:bg-indigo-500 transition-colors font-medium" %>
                            </div>
                          <% end %>
                        <% end %>

                        <p class="text-[10px] text-gray-600 mt-1">
                          <%= notification.created_at.in_time_zone.strftime("%d.%m.%Y, %H:%M") %>
                        </p>
                      </div>

                      <div class="flex items-center gap-1 flex-shrink-0">
                        <% unless notification.read %>
                          <span class="h-2 w-2 rounded-full bg-indigo-500 flex-shrink-0"></span>
                        <% end %>
                        <%= button_to notification_path(notification),
                              method: :delete,
                              class: "opacity-0 group-hover:opacity-100 transition-opacity text-gray-600 hover:text-red-400 p-0.5 rounded",
                              title: t('notifications.index.delete_one') do %>
                          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12"/>
                          </svg>
                        <% end %>
                      </div>
                    </div>
                  </div>
                </div>
              <% end %>
            </div>
          <% else %>
            <p class="px-4 py-4 text-sm text-gray-500 text-center">
              <%= t 'helpers.no_notif' %>
            </p>
          <% end %>

          <% if notifications&.size.to_i > 8 %>
            <div class="border-t border-gray-700/60 p-2">
              <%= link_to t('helpers.show_all'), notifications_path, class: "flex justify-center text-sm text-indigo-400 hover:text-indigo-300 py-1 transition-colors" %>
            </div>
          <% end %>
        </div>
      </div>


      <div class="hidden lg:block lg:h-6 lg:w-px lg:bg-gray-900/10" aria-hidden="true"></div>

      <div class="relative">
        <% if @current_user %>
          <button type="button" class="-m-1.5 flex items-center p-1.5"
                  data-action="click->dashboard#toggleProfileMenu"
                  aria-expanded="false" aria-haspopup="true">
            <% if @current_user && @current_user.avatar.attached? %>
              <%= image_tag url_for(@current_user.avatar), alt: "Profile Picture",
                            class: "h-8 w-8 rounded-full bg-gray-50" %>
            <% else %>
              <%= image_tag 'empty-avatar.jpg', class: "h-8 w-8 rounded-full bg-gray-50" %>
            <% end %>
            <span class="hidden lg:flex lg:items-center">
                  <span class="ml-4 text-sm font-semibold leading-6 text-white" aria-hidden="true">
                    <%= @current_user.name %>
                  </span>
                  <svg class="ml-2 h-5 w-5 text-gray-400"
                       viewBox="0 0 20 20"
                       fill="currentColor"
                       aria-hidden="true">
                    <path fill-rule="evenodd"
                          d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z"
                          clip-rule="evenodd"/>
                  </svg>
                </span>
          </button>
          <div class="hidden absolute right-0 z-10 mt-2.5 w-32 origin-top-right rounded-md bg-white py-2
              shadow-lg ring-1 ring-gray-900/5 focus:outline-none" role="menu" aria-orientation="vertical"
               aria-labelledby="user-menu-button" tabindex="-1" id="dashboard_profile_menu">
            <%= button_to t('buttons.profile'), user_profile_path(id: session[:current_user]), method: :get,
                          class: "block px-3 py-1 text-sm leading-6 text-gray-900" %>
            <%= button_to t('buttons.sign_out'), logout_path, method: :delete,
                          class: "block px-3 py-1 text-sm leading-6 text-gray-900" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>