<div class="bg-gray-900 min-h-screen">
  <div class="max-w-3xl mx-auto px-4 py-10 sm:px-6">

    <div class="flex items-center justify-between mb-8">
      <h1 class="text-2xl font-bold text-white"><%= t '.title' %></h1>
      <% if @notifications.any? %>
        <%= button_to t('.destroy_all', default: 'Удалить все'), destroy_all_notifications_notifications_path,
              method: :delete,
              class: "text-xs text-gray-500 hover:text-red-400 transition-colors px-3 py-1.5 rounded-lg border border-gray-700 hover:border-red-700/40" %>
      <% end %>
    </div>

    <% rendered_any = false %>
    <div class="space-y-2">
      <% @notifications.each do |notification| %>
        <% next if notification.notifiable.nil? && notification.actor.nil? %>
        <% rendered_any = true %>

        <div class="flex items-start gap-4 bg-gray-800 rounded-2xl p-4 border <%= notification.read ? 'border-gray-700/50' : 'border-indigo-700/40' %> hover:border-gray-600/80 transition-all">

          <%# Аватар %>
          <div class="flex-shrink-0">
            <% if notification.notifiable.is_a?(AdminMessage) %>
              <div class="w-12 h-12 rounded-xl bg-indigo-900/50 border border-indigo-700/40 flex items-center justify-center">
                <svg class="w-6 h-6 text-indigo-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M7.5 8.25h9m-9 3H12m-9.75 1.51c0 1.6 1.123 2.994 2.707 3.227 1.129.166 2.27.293 3.423.379.35.026.67.21.865.501L12 21l2.755-4.133a1.14 1.14 0 01.865-.501 48.172 48.172 0 003.423-.379c1.584-.233 2.707-1.626 2.707-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0012 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018z"/>
                </svg>
              </div>

            <% elsif notification.notifiable.is_a?(Game) %>
              <a href="<%= game_profile_path(notification.notifiable) %>" class="block rounded-xl overflow-hidden w-12 h-12 bg-gray-700">
                <% if notification.notifiable.cover.attached? %>
                  <%= image_tag url_for(notification.notifiable.cover), alt: notification.notifiable.name, class: "w-12 h-12 object-cover" %>
                <% else %>
                  <%= image_tag 'empty-avatar.jpg', alt: notification.notifiable.name, class: "w-12 h-12 object-cover" %>
                <% end %>
              </a>

            <% elsif notification.notifiable.is_a?(Jam) %>
              <a href="<%= jam_profile_path(notification.notifiable) %>" class="block rounded-xl overflow-hidden w-12 h-12 bg-gray-700">
                <% if notification.notifiable.cover.attached? %>
                  <%= image_tag url_for(notification.notifiable.cover), alt: notification.notifiable.name, class: "w-12 h-12 object-cover" %>
                <% else %>
                  <%= image_tag 'empty-avatar.jpg', alt: notification.notifiable.name, class: "w-12 h-12 object-cover" %>
                <% end %>
              </a>

            <% elsif notification.notifiable.is_a?(JamContributor) %>
              <% jam = notification.notifiable.jam %>
              <a href="<%= jam_profile_path(jam) %>" class="block rounded-xl overflow-hidden w-12 h-12 bg-gray-700">
                <% if jam.cover.attached? %>
                  <%= image_tag url_for(jam.cover), alt: jam.name, class: "w-12 h-12 object-cover" %>
                <% else %>
                  <%= image_tag 'empty-avatar.jpg', alt: jam.name, class: "w-12 h-12 object-cover" %>
                <% end %>
              </a>

            <% elsif notification.actor %>
              <a href="<%= user_profile_path(notification.actor) %>" class="block rounded-xl overflow-hidden w-12 h-12 bg-gray-700">
                <% if notification.actor.avatar.attached? %>
                  <%= image_tag url_for(notification.actor.avatar), alt: notification.actor.name, class: "w-12 h-12 object-cover" %>
                <% else %>
                  <%= image_tag 'empty-avatar.jpg', alt: notification.actor.name, class: "w-12 h-12 object-cover" %>
                <% end %>
              </a>
            <% end %>
          </div>

          <%# Контент %>
          <div class="flex-1 min-w-0">
            <div class="flex items-start justify-between gap-2">
              <div class="min-w-0">
                <% if notification.notifiable.is_a?(AdminMessage) %>
                  <p class="text-sm font-semibold text-indigo-300 truncate"><%= notification.notifiable.title %></p>
                  <% if notification.notifiable.body.present? %>
                    <p class="text-sm text-gray-300 mt-1 leading-relaxed"><%= notification.notifiable.body %></p>
                  <% end %>

                <% elsif notification.notifiable.is_a?(Game) %>
                  <p class="text-sm font-medium text-white truncate">
                    <a href="<%= game_profile_path(notification.notifiable) %>" class="hover:text-indigo-400 transition-colors">
                      <%= notification.notifiable.name %>
                    </a>
                  </p>
                  <p class="text-sm text-gray-400 mt-0.5"><%= notification_message(notification) %></p>

                <% elsif notification.notifiable.is_a?(Jam) || notification.notifiable.is_a?(JamContributor) %>
                  <% jam = notification.notifiable.is_a?(Jam) ? notification.notifiable : notification.notifiable.jam %>
                  <p class="text-sm font-medium text-white truncate">
                    <a href="<%= jam_profile_path(jam) %>" class="hover:text-indigo-400 transition-colors">
                      <%= jam.name %>
                    </a>
                  </p>
                  <p class="text-sm text-gray-400 mt-0.5"><%= notification_message(notification) %></p>

                <% elsif notification.actor %>
                  <p class="text-sm font-medium text-white truncate">
                    <a href="<%= user_profile_path(notification.actor) %>" class="hover:text-indigo-400 transition-colors">
                      <%= notification.actor.name %>
                    </a>
                  </p>
                  <p class="text-sm text-gray-400 mt-0.5"><%= notification_message(notification) %></p>
                <% end %>

                <%# Кнопка принятия инвайта в жюри %>
                <% if notification.action == "sent_jam_jury_invite" && notification.notifiable.is_a?(JamContributor) %>
                  <% contributor = notification.notifiable %>
                  <% jam = contributor.jam %>
                  <% if current_user && contributor.user_id == current_user.id && contributor.status == "pending" %>
                    <div class="mt-2">
                      <%= button_to t('.accept_jury_invite', default: 'Принять'), accept_contributor_invite_jam_path(jam, contributor_id: contributor.id),
                            method: :patch,
                            class: "rounded-lg bg-indigo-600 px-3 py-1.5 text-xs text-white hover:bg-indigo-500 transition-colors font-medium" %>
                    </div>
                  <% end %>
                <% end %>
              </div>

              <% unless notification.read %>
                <span class="flex-shrink-0 h-2 w-2 rounded-full bg-indigo-500 mt-1.5"></span>
              <% end %>
            </div>

            <p class="text-xs text-gray-600 mt-2">
              <%= notification.created_at.in_time_zone.strftime("%d.%m.%Y, %H:%M") %>
            </p>
          </div>
        </div>
      <% end %>
    </div>

    <% unless rendered_any %>
      <div class="text-center py-20">
        <svg class="mx-auto h-12 w-12 text-gray-700" fill="none" viewBox="0 0 24 24" stroke-width="1" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M14.857 17.082a23.848 23.848 0 005.454-1.31A8.967 8.967 0 0118 9.75v-.7V9A6 6 0 006 9v.75a8.967 8.967 0 01-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 01-5.714 0m5.714 0a3 3 0 11-5.714 0"/>
        </svg>
        <p class="mt-4 text-gray-500 text-sm"><%= t 'helpers.no_notif' %></p>
      </div>
    <% end %>
  </div>
</div>
