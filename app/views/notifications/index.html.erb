<div class="bg-white">
  <div class="mx-auto max-w-2xl px-4 py-16 sm:px-6 lg:max-w-7xl lg:px-8">
    <div class="flex justify-between items-center mb-4 px-4">
      <h2 class="text-2xl font-bold tracking-tight text-gray-900">
        <%= t '.title' %>
      </h2>
    </div>

    <% if @notifications.any? %>
      <% @notifications.each do |notification| %>
        <% next if notification.notifiable.nil? && notification.actor.nil? %>

        <div class="flex items-start px-4 py-3 border-b border-gray-200 hover:bg-gray-100 transition duration-200">
          <div class="flex-shrink-0 mr-3">
            <% if notification.notifiable.is_a?(AdminMessage) %>
              <div class="w-16 h-16 lg:w-20 lg:h-20 rounded-md bg-indigo-100 flex items-center justify-center">
                <svg class="w-8 h-8 text-indigo-500" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round"
                        d="M7.5 8.25h9m-9 3H12m-9.75 1.51c0 1.6 1.123 2.994 2.707 3.227 1.129.166 2.27.293 3.423.379.35.026.67.21.865.501L12 21l2.755-4.133a1.14 1.14 0 01.865-.501 48.172 48.172 0 003.423-.379c1.584-.233 2.707-1.626 2.707-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0012 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018z"/>
                </svg>
              </div>

            <% elsif notification.notifiable.is_a?(Game) %>
              <a href="<%= game_profile_path(notification.notifiable) %>">
                <% if notification.notifiable.cover.attached? %>
                  <%= image_tag url_for(notification.notifiable.cover),
                                alt: notification.notifiable.name,
                                class: "w-16 h-16 lg:w-20 lg:h-20 rounded-md object-cover" %>
                <% else %>
                  <%= image_tag 'empty-avatar.jpg', alt: notification.notifiable.name, class: "w-16 h-16 lg:w-20 lg:h-20 rounded-md bg-gray-200" %>
                <% end %>
              </a>

            <% elsif notification.notifiable.is_a?(Jam) %>
              <a href="<%= jam_profile_path(notification.notifiable) %>">
                <% if notification.notifiable.cover.attached? %>
                  <%= image_tag url_for(notification.notifiable.cover),
                                alt: notification.notifiable.name,
                                class: "w-16 h-16 lg:w-20 lg:h-20 rounded-md object-cover" %>
                <% else %>
                  <%= image_tag 'empty-avatar.jpg', alt: notification.notifiable.name, class: "w-16 h-16 lg:w-20 lg:h-20 rounded-md bg-gray-200" %>
                <% end %>
              </a>

            <% elsif notification.notifiable.is_a?(JamContributor) %>
              <% jam = notification.notifiable.jam %>
              <a href="<%= jam_profile_path(jam) %>">
                <% if jam.cover.attached? %>
                  <%= image_tag url_for(jam.cover),
                                alt: jam.name,
                                class: "w-16 h-16 lg:w-20 lg:h-20 rounded-md object-cover" %>
                <% else %>
                  <%= image_tag 'empty-avatar.jpg', alt: jam.name, class: "w-16 h-16 lg:w-20 lg:h-20 rounded-md bg-gray-200" %>
                <% end %>
              </a>

            <% elsif notification.actor %>
              <a href="<%= user_profile_path(notification.actor) %>">
                <% if notification.actor.avatar.attached? %>
                  <%= image_tag url_for(notification.actor.avatar),
                                alt: "Profile Picture",
                                class: "w-16 h-16 lg:w-20 lg:h-20 rounded-md object-cover" %>
                <% else %>
                  <%= image_tag 'empty-avatar.jpg',
                                alt: "Profile Picture",
                                class: "w-16 h-16 lg:w-20 lg:h-20 rounded-md bg-gray-200" %>
                <% end %>
              </a>
            <% end %>
          </div>

          <div class="flex-1">
            <p class="text-sm font-semibold text-gray-900">
              <% if notification.notifiable.is_a?(AdminMessage) %>
                <span class="text-indigo-600 font-semibold"><%= notification.notifiable.title %></span>

              <% elsif notification.notifiable.is_a?(Game) %>
                <a href="<%= game_profile_path(notification.notifiable) %>"
                   class="text-gray-600 hover:underline">
                  <%= notification.notifiable.name %>
                </a>

              <% elsif notification.notifiable.is_a?(Jam) %>
                <a href="<%= jam_profile_path(notification.notifiable) %>"
                   class="text-gray-600 hover:underline">
                  <%= notification.notifiable.name %>
                </a>

              <% elsif notification.notifiable.is_a?(JamContributor) %>
                <% jam = notification.notifiable.jam %>
                <a href="<%= jam_profile_path(jam) %>"
                   class="text-gray-600 hover:underline">
                  <%= jam.name %>
                </a>

              <% elsif notification.actor %>
                <a href="<%= user_profile_path(notification.actor) %>"
                   class="text-gray-600 hover:underline">
                  <%= notification.actor.name %>
                </a>
              <% end %>

              <%= notification_message(notification) %>
            </p>

            <% if notification.notifiable.is_a?(AdminMessage) %>
              <p class="text-sm text-gray-700 mt-1"><%= notification.notifiable.body %></p>
            <% end %>

            <% if notification.action == "sent_jam_jury_invite" && notification.notifiable.is_a?(JamContributor) %>
              <% contributor = notification.notifiable %>
              <% jam = contributor.jam %>

              <% if current_user && contributor.user_id == current_user.id && contributor.status == "pending" %>
                <div class="mt-2">
                  <%= button_to t('.accept_jury_invite'),
                                accept_contributor_invite_jam_path(jam, contributor_id: contributor.id),
                                method: :patch,
                                class: "rounded bg-indigo-600 px-3 py-1 text-white hover:bg-indigo-700" %>
                </div>
              <% end %>
            <% end %>

            <p class="text-xs text-gray-500">
              <%= notification.created_at.in_time_zone.strftime("%d.%m.%Y, %H:%M") %>
            </p>
          </div>
        </div>
      <% end %>
    <% else %>
      <p class="px-4 py-2 text-sm text-gray-600 text-center">
        <%= t 'helpers.no_notif' %>
      </p>
    <% end %>
  </div>
</div>