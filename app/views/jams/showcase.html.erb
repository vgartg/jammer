<div class="bg-gray-900 min-h-screen" data-controller="jams">
  <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center mb-8">
      <h2 class="text-3xl font-bold text-white"><%= t '.title' %></h2>
      <%= button_to t(".btn"), jams_new_path, method: :get,
                    class: "rounded-lg bg-indigo-600 py-2 px-4 text-sm font-medium text-white hover:bg-indigo-500 transition-colors" %>
    </div>

    <% if current_user %>
      <div class="flex gap-1 mb-8 bg-gray-800 rounded-xl p-1 w-fit border border-gray-700/60">
        <button data-action="click->jams#toggleJams"
                data-jams-target="showAll"
                class="px-4 py-2 rounded-lg text-sm font-medium text-gray-400 hover:text-white transition-colors">
          <%= t('.all_jams') %>
        </button>
        <button data-action="click->jams#toggleJams"
                data-jams-target="showMine"
                class="px-4 py-2 rounded-lg text-sm font-medium text-gray-400 hover:text-white transition-colors">
          <%= t('.my_jams') %>
        </button>
      </div>
    <% end %>

    <%= form_with url: jams_showcase_path, method: :get,
                  data: { action: "input->jams#search", jams_target: "searchForm" },
                  class: "mb-8" do |f| %>
      <div class="flex flex-wrap gap-3">
        <%= f.text_field :search,
                         value: params[:search],
                         placeholder: t('.search'),
                         data: { jams_target: "input" }, autocomplete: "off",
                         class: "block w-full max-w-sm px-4 py-2.5 bg-gray-800 border border-gray-700 rounded-xl text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent text-sm" %>
        <%= submit_tag t('.search_btn'),
                       class: "px-4 py-2.5 rounded-xl text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-500 transition-colors cursor-pointer" %>
      </div>

      <div class="mt-4">
        <div class="flex flex-wrap gap-2">
          <% @tags.each do |tag| %>
            <label data-jams-target="label"
                   class="relative flex items-center justify-center rounded-full px-3 py-1 cursor-pointer text-xs font-medium transition-all
                   <%= params[:tag_ids]&.include?(tag.id.to_s) ? 'bg-indigo-600 text-white border border-indigo-500' : 'bg-gray-800 text-gray-400 border border-gray-700 hover:border-gray-500 hover:text-gray-200' %>">
              <%= check_box_tag 'tag_ids[]', tag.id, params[:tag_ids]&.include?(tag.id.to_s),
                                id: "tag_#{tag.id}",
                                class: "absolute inset-0 w-full h-full opacity-0 cursor-pointer",
                                data: { jams_target: "tagCheckbox", action: "change->jams#search" } %>
              <span class="pointer-events-none"><%= tag.name %></span>
            </label>
          <% end %>
        </div>
      </div>

      <%= hidden_field_tag :tag_mode, params[:tag_mode] || 'all', data: { jams_target: "tagMode" } %>

      <div class="mt-3 flex flex-wrap items-center gap-4">
        <label class="flex items-center gap-2 cursor-pointer">
          <%= check_box_tag :toggle_tag_mode, 'any', params[:tag_mode] == 'any',
                            data: { action: "change->jams#toggleTagMode", jams_target: "toggleTagMode" },
                            class: "rounded border-gray-600 bg-gray-800 text-indigo-500" %>
          <span class="text-sm text-gray-400"><%= t(".checkbox") %></span>
        </label>

        <div id="reset-button" class="flex items-center gap-1 text-indigo-400 hover:text-indigo-300 cursor-pointer hidden text-sm"
             data-jams-target="resetButton" data-action="click->jams#resetTags">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" class="w-4 h-4">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
          </svg>
          <span><%= t '.reset_options' %></span>
        </div>
      </div>
    <% end %>

    <div id="autocomplete-results" class="autocomplete-results-popup">
      <%= render partial: 'autocomplete_results',
                 locals: { results: @search_results } if @search_results %>
    </div>

    <div data-jams-target="allJams">
      <h3 class="text-lg font-semibold text-white mb-5"><%= t('.all_jams') %></h3>
      <% if @jams.present? %>
        <%= render partial: 'showcase_grid', locals: { jams: @jams } %>
      <% else %>
        <p class="text-gray-500 mt-2"><%= t '.no_result' %></p>
      <% end %>
    </div>

    <div data-jams-target="myJams" class="hidden">
      <h3 class="text-lg font-semibold text-white mb-5"><%= t('.accepted') %></h3>
      <% if @jams_accepted.present? %>
        <%= render partial: 'showcase_grid', locals: { jams: @jams_accepted } %>
      <% else %>
        <p class="text-gray-500 mt-2"><%= t('.no_accepted') %></p>
      <% end %>

      <h3 class="text-lg font-semibold text-white mt-10 mb-5"><%= t('.under_moderation') %></h3>
      <% if @jams_under_moderation.present? %>
        <%= render partial: 'showcase_grid', locals: { jams: @jams_under_moderation } %>
      <% else %>
        <p class="text-gray-500 mt-2"><%= t('.no_under_moderation') %></p>
      <% end %>

      <h3 class="text-lg font-semibold text-white mt-10 mb-5"><%= t('.rejected') %></h3>
      <% if @jams_rejected.present? %>
        <%= render partial: 'showcase_grid', locals: { jams: @jams_rejected } %>
      <% else %>
        <p class="text-gray-500 mt-2"><%= t('.no_rejected') %></p>
      <% end %>
    </div>
  </div>
</div>
