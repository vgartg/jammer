<% if leaderboard_games&.any? %>
  <div class="mt-10 rounded-xl overflow-hidden ring-1 ring-white/10 shadow-lg">
    <div class="bg-gradient-to-r from-indigo-950 via-gray-800 to-gray-800 px-4 py-3 flex items-center gap-2 border-b border-white/10">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-yellow-400 flex-shrink-0" viewBox="0 0 20 20" fill="currentColor">
        <path fill-rule="evenodd" d="M10 2a1 1 0 011 1v1.323l3.954 1.582 1.599-.8a1 1 0 01.894 1.79l-1.233.616 1.738 5.42a1 1 0 01-.285 1.05A3.989 3.989 0 0115 14a3.989 3.989 0 01-2.667-1.019 1 1 0 01-.285-1.05l1.715-5.349L10 5.477l-3.763 1.105 1.715 5.349a1 1 0 01-.285 1.05A3.989 3.989 0 015 14a3.989 3.989 0 01-2.667-1.019 1 1 0 01-.285-1.05l1.738-5.42-1.233-.617a1 1 0 01.894-1.789l1.599.8L9 4.323V3a1 1 0 011-1zm-5 8.274l-.818 2.552c.25.112.526.174.818.174.292 0 .569-.062.818-.174L5 10.274zm10 0l-.818 2.552c.25.112.526.174.818.174.292 0 .569-.062.818-.174L15 10.274z" clip-rule="evenodd" />
      </svg>
      <h2 class="text-base font-semibold text-white"><%= t('jams.show.leaderboard_title') %></h2>
    </div>

    <div class="bg-gray-800 divide-y divide-white/5">
      <%# Dense rank: tied games share the same place number %>
      <% place = 0; prev_avg = nil %>
      <% leaderboard_games.each do |game| %>
        <% avg = game.jam_avg.to_f.round(1) %>
        <% place += 1 if avg != prev_avg; prev_avg = avg %>

        <% row_bg   = place == 1 ? 'bg-yellow-500/[0.06] hover:bg-yellow-500/10' :
                      place == 2 ? 'bg-slate-400/[0.04] hover:bg-slate-400/[0.08]' :
                      place == 3 ? 'bg-orange-500/[0.04] hover:bg-orange-500/[0.08]' :
                                   'hover:bg-white/[0.03]' %>
        <% badge_cls = place == 1 ? 'bg-yellow-500/20 text-yellow-400 ring-1 ring-yellow-500/50 shadow-[0_0_8px_rgba(234,179,8,0.25)]' :
                       place == 2 ? 'bg-slate-400/20 text-slate-300 ring-1 ring-slate-400/40' :
                       place == 3 ? 'bg-orange-600/20 text-orange-400 ring-1 ring-orange-600/40' :
                                    'bg-gray-700/60 text-gray-500 ring-1 ring-white/10' %>
        <% name_cls  = place == 1 ? 'text-yellow-300 hover:text-yellow-200' :
                       place == 2 ? 'text-slate-200 hover:text-white' :
                       place == 3 ? 'text-orange-300 hover:text-orange-200' :
                                    'text-gray-400 hover:text-gray-200' %>
        <% num_cls   = place == 1 ? 'text-yellow-400' : place == 2 ? 'text-slate-300' : place == 3 ? 'text-orange-400' : 'text-gray-500' %>
        <% star_cls  = place == 1 ? 'text-yellow-400' : place == 2 ? 'text-slate-400' : place == 3 ? 'text-orange-500' : 'text-gray-600' %>

        <div class="flex items-center gap-3 px-4 py-3 transition-colors <%= row_bg %>">
          <%# Place badge %>
          <div class="w-8 h-8 rounded-full flex items-center justify-center text-sm font-bold flex-shrink-0 <%= badge_cls %>">
            <% if place == 1 %>
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            <% else %>
              <%= place %>
            <% end %>
          </div>

          <%# Game name %>
          <div class="flex-1 min-w-0">
            <%= link_to game.name, game_profile_path(game, jam_id: jam.id),
                class: "text-sm font-medium truncate block #{name_cls}" %>
          </div>

          <%# Rating %>
          <div class="flex items-center gap-1 flex-shrink-0">
            <span class="text-sm font-semibold tabular-nums <%= num_cls %>"><%= avg %></span>
            <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 <%= star_cls %>" viewBox="0 0 20 20" fill="currentColor">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
            </svg>
          </div>
        </div>
      <% end %>
    </div>
  </div>
<% end %>
