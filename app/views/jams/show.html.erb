<div class="bg-white">
  <div class="pb-16 pt-6 sm:pb-24">
    <div class="mx-auto mt-8 max-w-2xl px-4 sm:px-6 lg:max-w-full lg:px-8">
      <div class="lg:grid lg:grid-cols-12 lg:gap-x-8">
        <div class="lg:col-span-5 lg:col-start-8">
          <div class="flex justify-between">
            <h1 class="text-2xl font-medium text-gray-900 break-all"><%= @jam.name %></h1>
          </div>
          <% if @jam.status != 1 %>
            <p class="mt-2 text-red-400 sm:text-sm">Данный джем
              <%= @jam.status == 0 ? 'находится на модерации' : 'отклонен модератором' %>
            </p>
          <% end %>
        </div>

        <!-- Image gallery -->
        <div class="mt-8 lg:col-span-7 lg:col-start-1 lg:row-span-3 lg:row-start-1 lg:mt-0">
          <div class="flex flex-col lg:grid-cols-1 lg:grid-rows-3 lg:gap-8">
            <% if @jam && @jam.cover.attached? %>
              <%= image_tag url_for(@jam.cover), alt: @jam.name,
                            class: "rounded-md bg-gray-200
                            object-cover object-center group-hover:opacity-75 w-3/4" %>
            <% else %>
              <div class="aspect-h-1 aspect-w-1 w-full overflow-hidden rounded-md bg-gray-200
                          lg:aspect-none group-hover:opacity-75 lg:h-80">
                <img src="https://via.placeholder.com/300" alt="<%= @jam.name %>"
                     class="object-cover object-center ">
              </div>
            <% end %>

            <div class="mt-5">
              <h2 class="text-lg font-medium text-gray-900">
                <%= t '.description' %>
              </h2>

              <div class="prose prose-sm mt-4 text-gray-500">
                <p class="trix-content">
                  <%= @jam.description %>
                </p>
              </div>
            </div>
          </div>
        </div>



        <div class="mt-4 lg:col-span-5">

          <div class="mt-5">
            <h2 class="text-lg font-medium text-gray-900">
              <%= t 'games.form.tags' %>
            </h2>
            <div class="mt-4 text-gray-500">
              <% if @jam.tags.any? %>
                <ul class="flex flex-wrap gap-2">
                  <% @jam.tags.each do |tag| %>
                    <li class="bg-indigo-200 px-4 py-2 rounded-full text-sm font-medium text-indigo-700">
                      <%= tag.name %>
                    </li>
                  <% end %>
                </ul>
              <% else %>
                <p class="text-gray-500"><%= t '.no_tags' %></p>
              <% end %>
            </div>
          </div>

          <% winners = @jam.jam_nominations.where.not(winner_game_id: nil).order(:position, :id) %>

          <% if winners.any? %>
            <div class="mt-10 rounded-lg border bg-white p-4">
              <h2 class="text-lg font-semibold text-gray-900">Победители по номинациям</h2>

              <div class="mt-4 space-y-3">
                <% winners.each do |n| %>
                  <% game = Game.find_by(id: n.winner_game_id) %>
                  <% next unless game %>

                  <div class="flex items-center justify-between rounded border px-3 py-2">
                    <div class="font-medium text-gray-900"><%= n.title %></div>
                    <div>
                      <%= link_to game.name,
                                  game_profile_path(game, jam_id: @jam.id),
                                  class: "text-indigo-600 hover:text-indigo-900" %>
                    </div>
                  </div>
                <% end %>
              </div>
            </div>
          <% end %>

          <div class="mt-10">
            <h2 class="text-lg font-medium text-gray-900">
              <%= t '.author' %>
            </h2>
            <div class="prose prose-sm mt-2 text-gray-500">
              <% if @jam.author.present? %>
                <a class="text-indigo-600 hover:text-indigo-900" href="<%= user_profile_path(@jam.author) %>">
                  <%= @jam.author.name %>
                </a>
              <% else %>
                <p class="text-gray-500">Автор не найден</p>
              <% end %>
            </div>
          </div>
          <% if current_user && @jam.can_manage?(current_user) %>
            <%= button_to t('.projects'), jam_show_projects_path(@jam), method: :get,
                          class: "mt-4 flex w-50 justify-center rounded-md border border-transparent bg-indigo-600 py-2 px-4 text-sm font-medium text-white shadow-sm hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2" %>

            <%= button_to t('.participants'), jam_show_participants_path(@jam), method: :get,
                          class: "mt-4 flex w-50 justify-center rounded-md border border-transparent bg-indigo-600 py-2 px-4 text-sm font-medium text-white shadow-sm hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2" %>

            <%= button_to t('.edit'), jam_edit_path(@jam), method: :get,
                          class: "mt-4 flex w-50 justify-center rounded-md border border-transparent bg-indigo-600 py-2 px-4 text-sm font-medium text-white shadow-sm hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2" %>

            <%= button_to t('.delete'), jam_destroy_path(@jam), method: :delete,
                          class: "mt-4 flex w-50 justify-center rounded-md border border-transparent bg-red-600 py-2 px-4 text-sm font-medium text-white shadow-sm hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-red-500 focus:ring-offset-2" %>

            <% if current_user && @jam.can_configure?(current_user) %>
              <%= button_to "Настройки оценок", rating_settings_jam_path(@jam), method: :get,
                            class: "mt-4 flex w-50 justify-center rounded-md border border-transparent bg-indigo-600 py-2 px-4 text-sm font-medium text-white shadow-sm hover:bg-indigo-700" %>

              <%= button_to "Настройки жюри", jury_settings_jam_path(@jam), method: :get,
                            class: "mt-4 flex w-50 justify-center rounded-md border border-transparent bg-indigo-600 py-2 px-4 text-sm font-medium text-white shadow-sm hover:bg-indigo-700" %>
            <% end %>
          <% elsif current_user.present? %>
            <%= button_to t('.projects'), jam_show_projects_path(@jam), method: :get,
                          class: "mt-4 flex w-50 justify-center rounded-md border border-transparent bg-indigo-600 py-2 px-4 text-sm font-medium text-white shadow-sm hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2" %>

            <%= button_to t('.participants'), jam_show_participants_path(@jam), method: :get,
                          class: "mt-4 flex w-50 justify-center rounded-md border border-transparent bg-indigo-600 py-2 px-4 text-sm font-medium text-white shadow-sm hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2" %>

            <div class="mt-4">
              <%= render "helpers/report_form", report_item: @jam %>
            </div>

            <% if @jsb.game_id.present? %>
              <% if @submission_open %>
                <%= button_to t('.edit_game'), game_edit_path(@game), method: :get,
                              class: "mt-4 flex w-50 justify-center rounded-md border border-transparent bg-indigo-600 py-2 px-4 text-sm font-medium text-white shadow-sm hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2" %>

                <button type="button"
                        class="mt-4 flex w-50 justify-center rounded-md border border-transparent bg-indigo-600 py-2 px-4 text-sm font-medium text-white shadow-sm hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2"
                        onclick="showWindow(document, 'favDialog')">
                  <%= t '.change_game' %>
                </button>
              <% else %>
                <p class="mt-4 text-sm text-gray-500">
                  Приём работ завершён. Редактирование и замена игры недоступны.
                </p>
              <% end %>

              <%= button_to t('.delete_game'), delete_project_jam_path(@jam), method: :patch,
                            class: "mt-4 flex w-50 justify-center rounded-md border border-transparent bg-red-600 py-2 px-4 text-sm font-medium text-white shadow-sm hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-red-500 focus:ring-offset-2" %>
            <% else %>
              <% if @submission_open %>
                <button type="button"
                        class="mt-4 flex w-50 justify-center rounded-md border border-transparent bg-indigo-600 py-2 px-4 text-sm font-medium text-white shadow-sm hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2"
                        onclick="showWindow(document, 'favDialog')">
                  <%= t '.add_game' %>
                </button>
              <% else %>
                <p class="mt-4 text-sm text-gray-500">
                  Приём работ завершён
                </p>
              <% end %>
            <% end %>
          <% end %>

        </div>
        </div>
      </div>
    </div>
  </div>
</div>