<% if users.empty? %>
  <div class="mt-3 text-sm text-gray-400"><%= t('jams.jury_search_results.empty') %></div>
<% else %>
  <div class="mt-3 divide-y divide-white/10 rounded-lg bg-gray-700 ring-1 ring-white/10">
    <% users.each do |u| %>
      <div class="flex items-center justify-between p-3">
        <div>
          <div class="font-medium text-white"><%= u.name %></div>
          <div class="text-sm text-gray-400"><%= u.email %></div>
        </div>

        <%= button_to t('jams.jury_search_results.invite'),
                      jury_invite_jam_path(jam, user_id: u.id),
                      method: :post,
                      class: "rounded bg-indigo-600 px-3 py-1 text-white hover:bg-indigo-700" %>
      </div>
    <% end %>
  </div>
<% end %>
