<div class="bg-gray-900 min-h-screen" data-controller="games">
  <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center mb-6">
      <h2 class="text-2xl font-bold tracking-tight text-white">
        <%= t '.title' %>
      </h2>
      <% if current_user && @jam.can_manage?(current_user) %>
        <span class="text-sm text-gray-400"><%= t('.remove_hint') %></span>
      <% end %>
    </div>

    <% unless @games.empty? %>
      <%= form_with url: jam_show_projects_path, method: :get,
                    data: { action: "input->games#search" },
                    class: "mb-6" do |f| %>
        <div class="flex flex-wrap gap-3">
          <%= f.text_field :search,
                           value: params[:search],
                           placeholder: t('games.showcase.search_placeholder'),
                           data: { games_target: "input" }, autocomplete: "off",
                           class: "block w-full max-w-xs px-4 py-2 bg-gray-800 border border-gray-700
                                   text-white rounded-lg shadow-sm focus:outline-none focus:ring-2
                                   focus:ring-indigo-500 focus:border-transparent sm:text-sm" %>
          <%= submit_tag t('games.showcase.search'),
                         class: "inline-flex items-center px-4 py-2 rounded-lg bg-indigo-600
                                 text-sm font-medium text-white hover:bg-indigo-700 transition-colors" %>
        </div>
      <% end %>

      <div id="autocomplete-results" class="autocomplete-results-popup"></div>

      <% if @games.present? %>
        <div class="grid grid-cols-1 gap-x-6 gap-y-8 sm:grid-cols-2 lg:grid-cols-4">
          <% @games.each do |game| %>
            <div class="group relative bg-gray-800 rounded-xl overflow-hidden ring-1 ring-white/10 hover:ring-indigo-500/50 transition-all">
              <div class="relative">
                <a href="<%= game_profile_path(game, jam_id: params[:id]) %>">
                  <% if game && game.cover.attached? %>
                    <%= image_tag url_for(game.cover), alt: game.name,
                                  class: "w-full h-48 object-cover group-hover:opacity-80 transition-opacity" %>
                  <% else %>
                    <%= image_tag 'empty-avatar.jpg', alt: game.name,
                                  class: "w-full h-48 object-cover group-hover:opacity-80 transition-opacity" %>
                  <% end %>
                </a>

                <% if @judged_game_ids.include?(game.id) %>
                  <div class="absolute top-2 right-2 bg-green-900/80 backdrop-blur-sm rounded-full px-2 py-1 flex items-center gap-1">
                    <svg class="w-4 h-4 text-green-400" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/>
                    </svg>
                  </div>
                <% else %>
                  <div class="absolute top-2 right-2 bg-gray-900/80 backdrop-blur-sm rounded-full px-2 py-1 flex items-center gap-1">
                    <span class="text-sm font-bold text-white"><%= game.jam_rating(@jam.id) %></span>
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-yellow-400" viewBox="0 0 20 20" fill="currentColor">
                      <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                    </svg>
                  </div>
                <% end %>
              </div>

              <div class="p-4">
                <% winner_titles = (@winner_titles_by_game_id && @winner_titles_by_game_id[game.id]) || [] %>
                <% if winner_titles.any? %>
                  <div class="mb-2 flex flex-wrap gap-1">
                    <% winner_titles.each do |title| %>
                      <span class="bg-amber-500/20 text-amber-300 px-2 py-0.5 rounded-full text-xs font-semibold border border-amber-500/30"><%= title %></span>
                    <% end %>
                  </div>
                <% end %>

                <h3 class="text-sm font-semibold text-white truncate">
                  <a href="<%= game_profile_path(game, jam_id: params[:id]) %>" class="hover:text-indigo-300 transition-colors">
                    <%= game.name %>
                  </a>
                </h3>
                <p class="mt-1 text-xs text-gray-400 line-clamp-2"><%= game.description %></p>

                <div class="mt-2 flex flex-wrap gap-1">
                  <% game.tags.each do |tag| %>
                    <span class="bg-gray-700 text-gray-300 px-2 py-0.5 rounded-full text-xs"><%= tag.name %></span>
                  <% end %>
                </div>

                <% if game.author.present? %>
                  <a href="<%= profile_path_for(game.author) %>" class="mt-2 block text-xs text-gray-400 hover:text-gray-200 truncate">
                    <%= game.author.name %>
                  </a>
                <% else %>
                  <p class="mt-2 text-xs text-gray-500"><%= t '.no_author' %></p>
                <% end %>

                <% if current_user && @jam.can_manage?(current_user) %>
                  <div class="mt-3 border-t border-gray-700 pt-3">
                    <%= button_to t('.remove_project'), remove_project_jam_path(@jam, game_id: game.id),
                                  method: :delete,
                                  data: { confirm: t('.remove_project_confirm') },
                                  class: "text-xs text-red-400 hover:text-red-300 underline" %>
                  </div>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="flex justify-center py-16">
          <p class="text-gray-400"><%= t '.not_found' %></p>
        </div>
      <% end %>
    <% else %>
      <div class="flex justify-center py-16">
        <p class="text-gray-400"><%= t '.no_projects' %></p>
      </div>
    <% end %>
  </div>
</div>
