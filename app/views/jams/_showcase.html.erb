<div class="bg-gray-900 min-h-screen">
  <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center mb-8">
      <h2 class="text-2xl font-bold text-white"><%= t('jams.showcase.title') %></h2>
      <%= button_to t('jams.showcase.btn'), jams_new_path, method: :get,
                    class: "rounded-lg bg-indigo-600 py-2 px-4 text-sm font-medium text-white hover:bg-indigo-500 transition-colors" %>
    </div>

    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
      <% @jams.each do |jam| %>
        <a href="/jams/<%= jam.id %>" class="group block rounded-2xl overflow-hidden bg-gray-800 border border-gray-700/60 hover:border-gray-500/80 transition-all hover:shadow-xl hover:shadow-black/40">
          <div class="aspect-video relative overflow-hidden bg-gray-700">
            <% if jam && jam.cover.attached? %>
              <%= image_tag url_for(jam.cover), alt: jam.name,
                    class: "w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" %>
            <% else %>
              <%= image_tag 'empty-avatar.jpg', alt: jam.name,
                    class: "w-full h-full object-cover" %>
            <% end %>
            <div class="absolute inset-0 bg-gradient-to-t from-gray-900/60 to-transparent"></div>
          </div>

          <div class="p-4">
            <h3 class="font-semibold text-white text-sm truncate group-hover:text-indigo-400 transition-colors">
              <%= jam.name %>
            </h3>
            <% if jam.description.present? %>
              <p class="mt-1 text-xs text-gray-400 line-clamp-2">
                <%= truncate(jam.description.to_s.strip, length: 100) %>
              </p>
            <% end %>
            <div class="mt-3 flex items-center gap-2">
              <% if jam.author.present? %>
                <% if jam.author.avatar.attached? %>
                  <%= image_tag url_for(jam.author.avatar), alt: jam.author.name,
                        class: "h-5 w-5 rounded-full object-cover" %>
                <% else %>
                  <%= image_tag 'empty-avatar.jpg', alt: jam.author.name,
                        class: "h-5 w-5 rounded-full object-cover" %>
                <% end %>
                <span class="text-xs text-gray-400 truncate"><%= jam.author.name %></span>
              <% else %>
                <span class="text-xs text-gray-600"><%= t('jams.showcase.no_author') %></span>
              <% end %>
            </div>
          </div>
        </a>
      <% end %>
    </div>
  </div>
</div>
