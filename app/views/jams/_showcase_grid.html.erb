<div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
  <% jams.each do |jam| %>
    <a href="<%= jam_profile_path(jam.id) %>" class="group block rounded-2xl overflow-hidden bg-gray-800 border border-gray-700/60 hover:border-gray-500/80 transition-all hover:shadow-xl hover:shadow-black/40">
      <div class="aspect-video relative overflow-hidden bg-gray-700">
        <% if jam && jam.cover.attached? %>
          <%= image_tag url_for(jam.cover), alt: jam.name,
                class: "w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" %>
        <% else %>
          <%= image_tag 'empty-avatar.jpg', alt: jam.name,
                class: "w-full h-full object-cover" %>
        <% end %>
        <div class="absolute inset-0 bg-gradient-to-t from-gray-900/60 to-transparent"></div>
      </div>

      <div class="p-4">
        <h3 class="font-semibold text-white text-sm truncate group-hover:text-indigo-400 transition-colors">
          <%= jam.name %>
        </h3>

        <% description_text = jam.description.to_plain_text.strip rescue jam.description.to_s.strip %>
        <% if description_text.present? %>
          <p class="mt-1 text-xs text-gray-400 line-clamp-2">
            <%= truncate(description_text, length: 100) %>
          </p>
        <% end %>

        <% if jam.tags.any? %>
          <div class="mt-2 flex flex-wrap gap-1">
            <% jam.tags.first(3).each do |tag| %>
              <span class="bg-gray-700 px-2 py-0.5 rounded-full text-xs text-gray-300"><%= tag.name %></span>
            <% end %>
          </div>
        <% end %>

        <div class="mt-3 grid grid-cols-2 gap-x-3 gap-y-1 text-xs text-gray-500">
          <% if jam.start_date.present? %>
            <div>
              <span class="text-gray-600"><%= t('jams.showcase_grid.start') %></span>
              <span class="text-gray-400"><%= jam.start_date.strftime("%d.%m.%Y") %></span>
            </div>
          <% end %>
          <% if jam.deadline.present? %>
            <div>
              <span class="text-gray-600"><%= t('jams.showcase_grid.deadline') %></span>
              <span class="text-gray-400"><%= jam.deadline.strftime("%d.%m.%Y") %></span>
            </div>
          <% end %>
        </div>

        <div class="mt-3 flex items-center gap-2">
          <% if jam.author.present? %>
            <% if jam.author.avatar.attached? %>
              <%= image_tag url_for(jam.author.avatar), alt: jam.author.name,
                    class: "h-5 w-5 rounded-full object-cover" %>
            <% else %>
              <%= image_tag 'empty-avatar.jpg', alt: jam.author.name,
                    class: "h-5 w-5 rounded-full object-cover" %>
            <% end %>
            <span class="text-xs text-gray-400 truncate"><%= jam.author.name %></span>
          <% else %>
            <span class="text-xs text-gray-600"><%= t('jams.showcase_grid.no_author') %></span>
          <% end %>
        </div>
      </div>
    </a>
  <% end %>
</div>
