<div class="bg-gray-900 min-h-screen">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-12">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-8">
      <h1 class="text-3xl font-bold text-white"><%= t '.title' %></h1>
      <% if current_user %>
        <%= link_to t('.new_team'), new_team_path,
            class: "rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white hover:bg-indigo-500 transition-colors" %>
      <% end %>
    </div>

    <div class="mb-8">
      <%= form_with url: teams_path, method: :get, local: true, class: "flex gap-3" do |f| %>
        <%= f.text_field :search, value: params[:search], placeholder: t('.search_placeholder'),
            class: "flex-1 max-w-sm rounded-xl border-0 bg-gray-800 py-2.5 px-4 text-white placeholder-gray-500 ring-1 ring-inset ring-gray-700 focus:ring-2 focus:ring-indigo-500 sm:text-sm" %>
        <%= f.submit t('.search_btn'), class: "rounded-xl bg-indigo-600 px-4 py-2.5 text-sm font-semibold text-white hover:bg-indigo-500 transition-colors cursor-pointer" %>
      <% end %>
    </div>

    <% if @teams.any? %>
      <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
        <% @teams.each do |team| %>
          <a href="<%= team_profile_path(team) %>" class="group relative flex flex-col rounded-2xl border border-gray-700/60 bg-gray-800 p-5 hover:border-gray-500/80 transition-all hover:shadow-xl hover:shadow-black/40">
            <div class="flex items-center gap-4 mb-3">
              <% if team.avatar.attached? %>
                <%= image_tag url_for(team.avatar), alt: team.name, class: "h-12 w-12 rounded-xl object-cover shrink-0" %>
              <% else %>
                <div class="h-12 w-12 rounded-xl bg-indigo-900/40 border border-indigo-700/40 flex items-center justify-center shrink-0">
                  <span class="text-xl font-bold text-indigo-400"><%= team.name.first.upcase %></span>
                </div>
              <% end %>
              <div class="min-w-0 flex-1">
                <h3 class="font-semibold text-white truncate group-hover:text-indigo-400 transition-colors">
                  <%= team.name %>
                </h3>
                <p class="text-xs text-gray-500 mt-0.5 truncate">
                  <%= t '.leader' %>: <%= team.leader.name %>
                </p>
              </div>
              <% if team.open_membership? %>
                <span class="shrink-0 rounded-full bg-green-900/30 border border-green-700/40 px-2 py-0.5 text-xs text-green-400">
                  <%= t 'teams._form.membership_open' %>
                </span>
              <% else %>
                <span class="shrink-0 rounded-full bg-gray-700/40 border border-gray-600/40 px-2 py-0.5 text-xs text-gray-400">
                  <%= t 'teams._form.membership_closed' %>
                </span>
              <% end %>
            </div>
            <% if team.description.present? %>
              <p class="text-sm text-gray-400 line-clamp-2 mb-3"><%= team.description %></p>
            <% end %>
            <div class="mt-auto flex items-center justify-between text-xs text-gray-600">
              <span class="text-gray-500">
                <%= t '.members_count', count: team.accepted_memberships.size %>
              </span>
              <span><%= team.created_at.strftime('%d.%m.%Y') %></span>
            </div>
          </a>
        <% end %>
      </div>
      <div class="mt-6">
        <%== pagy_nav(@pagy) if @pagy.pages > 1 %>
      </div>
    <% else %>
      <div class="text-center py-20">
        <svg class="mx-auto h-12 w-12 text-gray-700" fill="none" viewBox="0 0 24 24" stroke-width="1" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 0 0 3.741-.479 3 3 0 0 0-4.682-2.72m.94 3.198.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0 1 12 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 0 1 6 18.719m12 0a5.971 5.971 0 0 0-.941-3.197m0 0A5.995 5.995 0 0 0 12 12.75a5.995 5.995 0 0 0-5.058 2.772m0 0a3 3 0 0 0-4.681 2.72 8.986 8.986 0 0 0 3.74.477m.94-3.197a5.971 5.971 0 0 0-.94 3.197M15 6.75a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm6 3a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Zm-13.5 0a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Z"/>
        </svg>
        <h3 class="mt-4 text-sm font-semibold text-gray-400"><%= t '.no_teams' %></h3>
        <% if current_user %>
          <div class="mt-4">
            <%= link_to t('.new_team'), new_team_path,
                class: "inline-flex items-center rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white hover:bg-indigo-500 transition-colors" %>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
