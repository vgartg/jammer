<% @games.each do |game| %>
  <tr class="hover:bg-white/5 transition-colors text-gray-300">
    <td class="py-3 px-4 text-gray-500 text-xs"><%= game.id %></td>
    <td class="py-3 px-4">
      <% if game.author_id.present? %>
        <a class="text-indigo-300 hover:text-indigo-200 hover:underline break-all" href="<%= profile_path_for(game.author) %>">
          <%= truncate(game.author.name, length: 20) %>
        </a>
      <% else %>
        <span class="text-gray-500"><%= t('admin.shared.author_unknown') %></span>
      <% end %>
    </td>
    <td class="py-3 px-4">
      <%= link_to truncate(game.name, length: 25), game_profile_path(game),
                  class: 'text-indigo-300 hover:text-indigo-200 hover:underline break-all' %>
    </td>
    <td class="py-3 px-4">
      <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-semibold
        <%= game.status.to_s == '1' ? 'bg-green-500/20 text-green-300 ring-1 ring-green-500/30' :
            game.status.to_s == '2' ? 'bg-red-500/20 text-red-300 ring-1 ring-red-500/30' :
            'bg-yellow-500/20 text-yellow-300 ring-1 ring-yellow-500/30' %>">
        <%= game.status %>
      </span>
    </td>
    <td class="py-3 px-4 text-gray-500 text-xs"><%= game.created_at.strftime("%d.%m.%Y %H:%M") %></td>
    <td class="py-3 px-4">
      <div class="flex gap-2">
        <%= link_to t('admin.shared.edit'), edit_admin_game_path(game),
                    class: 'rounded bg-indigo-600/80 text-white py-1 px-3 text-xs hover:bg-indigo-600 transition-colors' %>
        <%= link_to t('admin.shared.delete'), admin_game_path(game),
                    class: 'rounded bg-red-600/80 text-white py-1 px-3 text-xs hover:bg-red-600 transition-colors',
                    data: { turbo_method: :delete, turbo_confirm: t('admin.shared.confirm') } %>
      </div>
    </td>
  </tr>
<% end %>
