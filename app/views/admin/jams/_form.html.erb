<div class="bg-gray-900 min-h-screen px-4 py-8 sm:px-6 lg:px-8">
  <div class="mx-auto max-w-3xl">

    <div class="flex items-center gap-4 mb-6">
      <%= link_to t('admin.shared.back'),
            request.referer && URI(request.referer).path != request.fullpath ? URI(request.referer).path : admin_jams_path,
            class: 'rounded-lg bg-gray-700 px-4 py-2 text-sm font-medium text-gray-300 hover:bg-gray-600 transition-colors' %>
      <h1 class="text-xl font-bold text-white truncate"><%= jam.name %></h1>
    </div>

    <%= form_with model: [:admin, jam], class: "space-y-5" do |f| %>

      <%# Name + description %>
      <div class="bg-gray-800 rounded-xl ring-1 ring-white/10 p-5">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <%= f.label :name, class: 'block text-sm font-medium text-gray-300 mb-1' %>
            <%= f.text_field :name, class: 'w-full rounded-lg bg-gray-700 border-0 ring-1 ring-white/10 px-3 py-2 text-white placeholder-gray-400 focus:ring-2 focus:ring-indigo-500 focus:outline-none text-sm' %>
          </div>
          <div>
            <%= f.label :description, class: 'block text-sm font-medium text-gray-300 mb-1' %>
            <%= f.text_field :description, class: 'w-full rounded-lg bg-gray-700 border-0 ring-1 ring-white/10 px-3 py-2 text-white placeholder-gray-400 focus:ring-2 focus:ring-indigo-500 focus:outline-none text-sm' %>
          </div>
        </div>
      </div>

      <%# Dates %>
      <div class="bg-gray-800 rounded-xl ring-1 ring-white/10 p-5">
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
          <div>
            <%= f.label :start_date, t('.start_date'), class: 'block text-sm font-medium text-gray-300 mb-1' %>
            <%= f.date_field :start_date, required: true,
                  class: 'w-full rounded-lg bg-gray-700 border-0 ring-1 ring-white/10 px-3 py-2 text-white focus:ring-2 focus:ring-indigo-500 focus:outline-none text-sm' %>
          </div>
          <div>
            <%= f.label :deadline, t('.deadline'), class: 'block text-sm font-medium text-gray-300 mb-1' %>
            <%= f.date_field :deadline, required: true,
                  class: 'w-full rounded-lg bg-gray-700 border-0 ring-1 ring-white/10 px-3 py-2 text-white focus:ring-2 focus:ring-indigo-500 focus:outline-none text-sm' %>
          </div>
          <div>
            <%= f.label :end_date, t('.end_date'), class: 'block text-sm font-medium text-gray-300 mb-1' %>
            <%= f.date_field :end_date, required: true,
                  class: 'w-full rounded-lg bg-gray-700 border-0 ring-1 ring-white/10 px-3 py-2 text-white focus:ring-2 focus:ring-indigo-500 focus:outline-none text-sm' %>
          </div>
        </div>
      </div>

      <%# Status %>
      <div class="bg-gray-800 rounded-xl ring-1 ring-white/10 p-5" data-controller="status">
        <p class="text-xs text-gray-500 mb-2"><%= t('admin.shared.status_hint') %></p>
        <%= f.select :status, options_for_select([['0', 0], ['1', 1], ['2', 2]], f.object.status),
              { target: 'status' },
              class: 'w-full sm:w-40 rounded-lg bg-gray-700 border-0 ring-1 ring-white/10 px-3 py-2 text-white focus:ring-2 focus:ring-indigo-500 focus:outline-none text-sm',
              id: "jam_status",
              data: { action: 'change->status#updateReasonField', status_target: 'status' } %>
        <div data-status-target="reasonField" class="mt-4" style="<%= f.object.status == 2 ? '' : 'display: none;' %>">
          <p class="text-sm font-medium text-gray-300 mb-2"><%= t('admin.shared.rejection_reason') %></p>
          <div class="flex flex-wrap gap-2 mb-2">
            <% [t('admin.shared.rejection_reasons.no_reason'),
                t('admin.shared.rejection_reasons.indecent_content'),
                t('admin.shared.rejection_reasons.advertising'),
                t('admin.shared.rejection_reasons.plagiarism')].each do |val| %>
              <button type="button" data-action="click->status#pick" data-status-value-param="<%= val %>"
                      class="text-xs px-3 py-1.5 rounded-lg bg-gray-700 hover:bg-gray-600 border border-gray-600 text-gray-300 transition-colors">
                <%= val %>
              </button>
            <% end %>
          </div>
          <%= f.text_field :reason, placeholder: t('admin.shared.rejection_reason_placeholder'),
                data: { status_target: 'customReason' },
                class: 'w-full rounded-lg bg-gray-700 border-0 ring-1 ring-white/10 px-3 py-2 text-white placeholder-gray-400 focus:ring-2 focus:ring-indigo-500 focus:outline-none text-sm' %>
        </div>
      </div>

      <%# Cover %>
      <div class="bg-gray-800 rounded-xl ring-1 ring-white/10 p-5">
        <p class="text-sm font-medium text-gray-300 mb-3"><%= t('.cover') %></p>
        <% if @jam&.cover&.attached? %>
          <div class="mb-3">
            <%= image_tag url_for(@jam.cover), alt: @jam.name, class: "max-h-48 rounded-lg object-cover" %>
          </div>
        <% end %>
        <%= f.file_field :cover,
              class: 'w-full text-sm text-gray-400 file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:bg-gray-700 file:text-gray-300 hover:file:bg-gray-600 file:cursor-pointer file:transition-colors' %>
      </div>

      <%# Logo %>
      <div class="bg-gray-800 rounded-xl ring-1 ring-white/10 p-5">
        <p class="text-sm font-medium text-gray-300 mb-3"><%= t('.logo') %></p>
        <% if @jam&.logo&.attached? %>
          <div class="mb-3">
            <%= image_tag url_for(@jam.logo), alt: @jam.name, class: "max-h-32 rounded-lg object-contain" %>
          </div>
        <% end %>
        <%= f.file_field :logo,
              class: 'w-full text-sm text-gray-400 file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:bg-gray-700 file:text-gray-300 hover:file:bg-gray-600 file:cursor-pointer file:transition-colors' %>
      </div>

      <%# Tags %>
      <div class="bg-gray-800 rounded-xl ring-1 ring-white/10 p-5">
        <p class="text-sm font-medium text-gray-300 mb-3"><%= t('admin.shared.tags') %></p>
        <div class="flex flex-wrap gap-x-6 gap-y-2">
          <%= f.collection_check_boxes(:tag_ids, Tag.all, :id, :name) do |b| %>
            <label class="flex items-center gap-2 cursor-pointer">
              <%= b.check_box(class: "h-4 w-4 rounded border-gray-600 bg-gray-700 text-indigo-500 focus:ring-indigo-500 focus:ring-offset-gray-800") %>
              <span class="text-sm text-gray-300"><%= b.object.name %></span>
            </label>
          <% end %>
        </div>
      </div>

      <%# Submit %>
      <div class="flex justify-end">
        <%= f.submit t('admin.shared.save'),
              class: 'rounded-lg bg-indigo-600 px-6 py-2 text-sm font-semibold text-white hover:bg-indigo-700 transition-colors cursor-pointer' %>
      </div>

    <% end %>
  </div>
</div>
