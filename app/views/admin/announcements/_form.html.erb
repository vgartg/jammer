<%= form_with model: [:admin, @announcement], local: true do |f| %>
  <div class="bg-gray-800 rounded-xl ring-1 ring-white/10 p-6 space-y-6 max-w-2xl">

    <div>
      <%= f.label :announcement_type, t('admin.announcements.form.type_label'),
                  class: 'block text-sm font-medium text-gray-300 mb-1' %>
      <%= f.select :announcement_type,
                   [[t('admin.announcements.form.type_general'), 'general'],
                    [t('admin.announcements.form.type_release'), 'release']],
                   {},
                   id: 'announcement_type_select',
                   class: 'block w-full rounded-lg bg-gray-700 border-0 ring-1 ring-white/10 px-3 py-2 text-sm text-white focus:ring-2 focus:ring-indigo-500 focus:outline-none' %>
    </div>

    <div id="version_field" class="<%= @announcement.announcement_type == 'release' ? '' : 'hidden' %>">
      <%= f.label :version, t('admin.announcements.form.version'),
                  class: 'block text-sm font-medium text-gray-300 mb-1' %>
      <%= f.text_field :version, placeholder: '0.7.0',
                       class: 'block w-full rounded-lg bg-gray-700 border-0 ring-1 ring-white/10 px-3 py-2 text-sm text-white focus:ring-2 focus:ring-indigo-500 focus:outline-none' %>
      <p class="text-xs text-gray-500 mt-1"><%= t('admin.announcements.form.version_hint') %></p>
    </div>

    <div>
      <%= f.label :title_en, t('admin.announcements.form.title_en'),
                  class: 'block text-sm font-medium text-gray-300 mb-1' %>
      <%= f.text_field :title_en, required: true,
                       class: 'block w-full rounded-lg bg-gray-700 border-0 ring-1 ring-white/10 px-3 py-2 text-sm text-white focus:ring-2 focus:ring-indigo-500 focus:outline-none' %>
    </div>

    <div>
      <%= f.label :title_ru, t('admin.announcements.form.title_ru'),
                  class: 'block text-sm font-medium text-gray-300 mb-1' %>
      <%= f.text_field :title_ru, required: true,
                       class: 'block w-full rounded-lg bg-gray-700 border-0 ring-1 ring-white/10 px-3 py-2 text-sm text-white focus:ring-2 focus:ring-indigo-500 focus:outline-none' %>
    </div>

    <div>
      <%= f.label :body_en, t('admin.announcements.form.body_en'),
                  class: 'block text-sm font-medium text-gray-300 mb-1' %>
      <%= f.text_area :body_en, rows: 6,
                      class: 'block w-full rounded-lg bg-gray-700 border-0 ring-1 ring-white/10 px-3 py-2 text-sm text-white focus:ring-2 focus:ring-indigo-500 focus:outline-none' %>
    </div>

    <div>
      <%= f.label :body_ru, t('admin.announcements.form.body_ru'),
                  class: 'block text-sm font-medium text-gray-300 mb-1' %>
      <%= f.text_area :body_ru, rows: 6,
                      class: 'block w-full rounded-lg bg-gray-700 border-0 ring-1 ring-white/10 px-3 py-2 text-sm text-white focus:ring-2 focus:ring-indigo-500 focus:outline-none' %>
    </div>

    <div class="flex flex-wrap gap-3 pt-2">
      <%= f.submit t('admin.announcements.form.save'),
                   class: 'rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white hover:bg-indigo-700 cursor-pointer transition-colors' %>
      <% unless @announcement.published? %>
        <%= f.submit t('admin.announcements.form.save_and_publish'),
                     name: 'publish',
                     class: 'rounded-lg bg-green-600 px-4 py-2 text-sm font-semibold text-white hover:bg-green-700 cursor-pointer transition-colors' %>
      <% else %>
        <%= f.submit t('admin.announcements.form.unpublish'),
                     name: 'unpublish',
                     class: 'rounded-lg bg-amber-500 px-4 py-2 text-sm font-semibold text-white hover:bg-amber-600 cursor-pointer transition-colors' %>
      <% end %>
      <%= link_to t('admin.shared.back'), admin_announcements_path,
                  class: 'rounded-lg border border-gray-600 px-4 py-2 text-sm font-medium text-gray-300 hover:bg-gray-700 transition-colors' %>
    </div>
  </div>
<% end %>

<script>
  document.getElementById('announcement_type_select')?.addEventListener('change', function() {
    const versionField = document.getElementById('version_field');
    versionField.classList.toggle('hidden', this.value !== 'release');
  });
</script>
