<div class="bg-gray-900 min-h-screen px-4 py-8 sm:px-6 lg:px-8">
  <div class="mx-auto max-w-7xl">
    <div class="flex items-center justify-between mb-6 flex-wrap gap-4">
      <h1 class="text-2xl font-bold text-white"><%= t('.title') %></h1>
      <%= link_to t('.create_user'), new_admin_user_path,
                  class: 'rounded-lg bg-green-600 px-4 py-2 text-sm font-medium text-white hover:bg-green-700 transition-colors' %>
    </div>

    <%= form_with url: admin_users_path, method: :get, local: true, class: "mb-6" do |form| %>
      <div class="flex flex-wrap gap-3">
        <%= form.text_field :query, value: params[:query], placeholder: t('.search_label'),
                            class: "rounded-lg bg-gray-800 border-0 ring-1 ring-white/10 px-3 py-2 text-sm text-white
                                    placeholder-gray-500 focus:ring-2 focus:ring-indigo-500 focus:outline-none w-full max-w-xs" %>
        <%= form.submit t('admin.shared.search'),
                        class: "rounded-lg bg-indigo-600 px-4 py-2 text-sm font-medium text-white hover:bg-indigo-700 transition-colors cursor-pointer" %>
        <%= link_to t('admin.shared.reset'), admin_users_path,
                    class: "rounded-lg bg-gray-700 px-4 py-2 text-sm font-medium text-gray-300 hover:bg-gray-600 transition-colors" %>
      </div>
    <% end %>

    <% if @users.any? %>
      <div class="bg-gray-800 rounded-xl ring-1 ring-white/10 overflow-hidden">
        <table class="min-w-full text-sm">
          <thead>
            <tr class="border-b border-white/10 text-gray-400 text-xs uppercase tracking-wider">
              <th class="py-3 px-4 text-left">
                <%= link_to '#', admin_users_path(sort_by: 'id', direction: toggle_direction('id')),
                            class: "hover:text-white flex items-center gap-1" %>
                <%= sort_arrow('id') %>
              </th>
              <th class="py-3 px-4 text-left">
                <%= link_to t('admin.shared.name'), admin_users_path(sort_by: 'name', direction: toggle_direction('name')),
                            class: "hover:text-white" %>
                <%= sort_arrow('name') %>
              </th>
              <th class="py-3 px-4 text-left">Email</th>
              <th class="py-3 px-4 text-left">
                <%= link_to t('admin.shared.role'), admin_users_path(sort_by: 'role', direction: toggle_direction('role')),
                            class: "hover:text-white" %>
                <%= sort_arrow('role') %>
              </th>
              <th class="py-3 px-4 text-left">
                <%= link_to t('admin.shared.created_at'), admin_users_path(sort_by: 'created_at', direction: toggle_direction('created_at')),
                            class: "hover:text-white" %>
                <%= sort_arrow('created_at') %>
              </th>
              <th class="py-3 px-4"></th>
            </tr>
          </thead>
          <tbody class="divide-y divide-white/5">
            <%= render partial: 'admin/users/user' %>
          </tbody>
        </table>
      </div>
      <div class="mt-4">
        <%= render partial: 'helpers/pagy' %>
      </div>
    <% else %>
      <div class="text-center py-16">
        <p class="text-gray-400"><%= t('.not_found', query: params[:query]) %></p>
      </div>
    <% end %>
  </div>
</div>
