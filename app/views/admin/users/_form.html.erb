<div class="bg-gray-900 min-h-screen px-4 py-8 sm:px-6 lg:px-8" data-controller="settings">

  <%# Header %>
  <div class="mx-auto max-w-5xl">
    <div class="flex items-center gap-4 mb-6">
      <%= link_to t('admin.shared.back'),
            request.referer && URI(request.referer).path != request.fullpath ? URI(request.referer).path : admin_users_path,
            class: 'rounded-lg bg-gray-700 px-4 py-2 text-sm font-medium text-gray-300 hover:bg-gray-600 transition-colors shrink-0' %>
      <h1 class="text-xl font-bold text-white truncate"><%= user.name %></h1>
      <span class="text-xs text-gray-500 shrink-0">#<%= user.id %></span>
    </div>

    <%# Tabs %>
    <div class="flex flex-wrap gap-2 mb-6">
      <% [
        ['profile',         t('.tabs.profile')],
        ['user_experience', t('.tabs.user_experience')],
        ['games',           t('.tabs.games')],
        ['jams',            t('.tabs.jams')],
        ['sessions',        t('.tabs.sessions')],
        ['notifications',   t('.tabs.notifications')],
      ].each_with_index do |(section, label), i| %>
        <button data-target="settings.button"
                data-action="click->settings#showSection"
                data-section="<%= section %>"
                class="rounded-lg px-4 py-2 text-sm font-medium transition-colors
                       <%= i == 0 ? 'bg-indigo-600 text-white' : 'bg-gray-700 text-gray-300 hover:bg-gray-600' %>">
          <%= label %>
        </button>
      <% end %>
    </div>

    <%# Frozen notice %>
    <% if @user.is_frozen? %>
      <div class="mb-6 rounded-xl bg-red-900/30 border border-red-700/50 px-4 py-3 text-sm">
        <p class="font-semibold text-red-300"><%= t('.frozen.title') %></p>
        <p class="text-red-400 mt-1"><%= t('.frozen.reason') %> <%= @user.frozen_reason %></p>
        <p class="text-red-400"><%= t('.frozen.unfreeze_at') %>
          <%= @user.unfreeze_at.present? ? @user.unfreeze_at.in_time_zone.strftime("%d.%m.%Y %H:%M") : t('.freeze.durations.forever') %>
        </p>
      </div>
    <% end %>

    <%# ===== PROFILE SECTION ===== %>
    <div data-settings-target="section" data-section="profile">
      <%= form_with model: [:admin, user], class: "space-y-5" do |f| %>

        <%# Account fields %>
        <div class="bg-gray-800 rounded-xl ring-1 ring-white/10 p-5">
          <h2 class="text-xs font-semibold uppercase tracking-widest text-gray-500 mb-4">Account</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
            <div>
              <%= f.label :email, class: 'block text-sm font-medium text-gray-300 mb-1' %>
              <%= f.email_field :email, class: 'w-full rounded-lg bg-gray-700 border-0 ring-1 ring-white/10 px-3 py-2 text-white placeholder-gray-400 focus:ring-2 focus:ring-indigo-500 focus:outline-none text-sm' %>
            </div>
            <div>
              <%= f.label :name, class: 'block text-sm font-medium text-gray-300 mb-1' %>
              <%= f.text_field :name, class: 'w-full rounded-lg bg-gray-700 border-0 ring-1 ring-white/10 px-3 py-2 text-white placeholder-gray-400 focus:ring-2 focus:ring-indigo-500 focus:outline-none text-sm' %>
            </div>
            <div>
              <%= f.label :role, class: 'block text-sm font-medium text-gray-300 mb-1' %>
              <%= f.select :role, User.roles.keys.map { |r| [r.titleize, r] }, {},
                    class: 'w-full rounded-lg bg-gray-700 border-0 ring-1 ring-white/10 px-3 py-2 text-white focus:ring-2 focus:ring-indigo-500 focus:outline-none text-sm' %>
            </div>
            <div class="flex flex-col justify-end">
              <label class="flex items-center gap-2 cursor-pointer mt-6">
                <%= f.check_box :email_confirmed, class: 'h-4 w-4 rounded border-gray-600 bg-gray-700 text-indigo-500 focus:ring-indigo-500', checked: user.email_confirmed %>
                <span class="text-sm text-gray-300">Email confirmed</span>
              </label>
            </div>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mt-4">
            <div>
              <%= f.label :password, class: 'block text-sm font-medium text-gray-300 mb-1' %>
              <%= f.password_field :password, class: 'w-full rounded-lg bg-gray-700 border-0 ring-1 ring-white/10 px-3 py-2 text-white placeholder-gray-400 focus:ring-2 focus:ring-indigo-500 focus:outline-none text-sm' %>
            </div>
            <div>
              <%= f.label :password_confirmation, class: 'block text-sm font-medium text-gray-300 mb-1' %>
              <%= f.password_field :password_confirmation, class: 'w-full rounded-lg bg-gray-700 border-0 ring-1 ring-white/10 px-3 py-2 text-white placeholder-gray-400 focus:ring-2 focus:ring-indigo-500 focus:outline-none text-sm' %>
            </div>
          </div>
        </div>

        <%# Avatar + background %>
        <div class="bg-gray-800 rounded-xl ring-1 ring-white/10 p-5">
          <h2 class="text-xs font-semibold uppercase tracking-widest text-gray-500 mb-4">Media</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            <div>
              <label class="block text-sm font-medium text-gray-300 mb-2"><%= t('.avatar') %></label>
              <div class="flex items-center gap-4 bg-gray-700/50 rounded-lg p-3">
                <% if user&.avatar&.attached? %>
                  <%= image_tag url_for(user.avatar), alt: "Avatar", class: "rounded-full h-16 w-16 object-cover shrink-0" %>
                <% else %>
                  <%= image_tag 'empty-avatar.jpg', alt: "Avatar", class: "rounded-full h-16 w-16 object-cover shrink-0" %>
                <% end %>
                <div>
                  <%= f.file_field :avatar, class: "w-full text-xs text-gray-400 file:mr-3 file:py-1.5 file:px-3 file:rounded-lg file:border-0 file:bg-gray-600 file:text-gray-300 hover:file:bg-gray-500 file:cursor-pointer file:transition-colors", accept: "image/jpeg,image/png" %>
                  <%= render partial: 'helpers/cropper_modal_admin' %>
                </div>
              </div>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-300 mb-2"><%= t('.background_image') %></label>
              <div data-controller="background-image" class="bg-gray-700/50 rounded-lg p-3 relative">
                <% if user.background_image.attached? %>
                  <img data-background-image-target="currentBackgroundImg"
                       src="<%= url_for(user.background_image) %>"
                       alt="Background" class="max-h-32 mb-2 object-cover rounded-md w-full" />
                <% end %>
                <img data-background-image-target="previewImg" src="#"
                     alt="<%= t('.background_preview_alt') %>"
                     class="mt-2 hidden w-full h-auto object-cover rounded-md max-h-32">
                <input data-background-image-target="input" type="file" name="user[background_image]"
                       id="background_image"
                       class="absolute inset-0 opacity-0 cursor-pointer" accept="image/*">
                <label for="background_image" class="block text-xs text-gray-400 cursor-pointer hover:text-gray-300 text-center mt-1">
                  <%= t('.upload_new_background') %>
                </label>
              </div>
            </div>
          </div>
        </div>

        <%# Profile details %>
        <div class="bg-gray-800 rounded-xl ring-1 ring-white/10 p-5">
          <h2 class="text-xs font-semibold uppercase tracking-widest text-gray-500 mb-4">Profile</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
            <div>
              <%= f.label :real_name, class: 'block text-sm font-medium text-gray-300 mb-1' %>
              <%= f.text_field :real_name, class: 'w-full rounded-lg bg-gray-700 border-0 ring-1 ring-white/10 px-3 py-2 text-white placeholder-gray-400 focus:ring-2 focus:ring-indigo-500 focus:outline-none text-sm' %>
            </div>
            <div>
              <%= f.label :location, class: 'block text-sm font-medium text-gray-300 mb-1' %>
              <%= f.text_field :location, class: 'w-full rounded-lg bg-gray-700 border-0 ring-1 ring-white/10 px-3 py-2 text-white placeholder-gray-400 focus:ring-2 focus:ring-indigo-500 focus:outline-none text-sm' %>
            </div>
            <div>
              <%= f.label :status, class: 'block text-sm font-medium text-gray-300 mb-1' %>
              <%= f.text_field :status, class: 'w-full rounded-lg bg-gray-700 border-0 ring-1 ring-white/10 px-3 py-2 text-white placeholder-gray-400 focus:ring-2 focus:ring-indigo-500 focus:outline-none text-sm' %>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-300 mb-1"><%= t('.personal_link') %></label>
              <%= f.text_field :link_username, placeholder: 'username',
                    class: 'w-full rounded-lg bg-gray-700 border-0 ring-1 ring-white/10 px-3 py-2 text-white placeholder-gray-400 focus:ring-2 focus:ring-indigo-500 focus:outline-none text-sm',
                    pattern: '[a-zA-Z0-9-]+' %>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-300 mb-1"><%= t('.phone_number') %></label>
              <%= f.text_field :phone_number, type: 'tel', placeholder: '+7 (___) ___-__-__',
                    class: 'w-full rounded-lg bg-gray-700 border-0 ring-1 ring-white/10 px-3 py-2 text-white placeholder-gray-400 focus:ring-2 focus:ring-indigo-500 focus:outline-none text-sm' %>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-300 mb-1"><%= t('.birthday') %></label>
              <%= f.text_field :birthday, type: 'date', value: user.birthday,
                    class: 'w-full rounded-lg bg-gray-700 border-0 ring-1 ring-white/10 px-3 py-2 text-white focus:ring-2 focus:ring-indigo-500 focus:outline-none text-sm' %>
            </div>
            <div>
              <%= f.label :visibility, class: 'block text-sm font-medium text-gray-300 mb-1' %>
              <%= f.select :visibility, options_for_select([['All'], ['Friends'], ['None']], selected: user.visibility), {},
                    class: 'w-full rounded-lg bg-gray-700 border-0 ring-1 ring-white/10 px-3 py-2 text-white focus:ring-2 focus:ring-indigo-500 focus:outline-none text-sm' %>
            </div>
            <div>
              <%= f.label :jams_participating_visibility, class: 'block text-sm font-medium text-gray-300 mb-1' %>
              <%= f.select :jams_participating_visibility, options_for_select([['All'], ['Friends'], ['None']], selected: user.jams_participating_visibility), {},
                    class: 'w-full rounded-lg bg-gray-700 border-0 ring-1 ring-white/10 px-3 py-2 text-white focus:ring-2 focus:ring-indigo-500 focus:outline-none text-sm' %>
            </div>
            <div>
              <%= f.label :theme, class: 'block text-sm font-medium text-gray-300 mb-1' %>
              <%= f.select :theme, options_for_select([['Light'], ['Dark']], selected: user.theme), {},
                    class: 'w-full rounded-lg bg-gray-700 border-0 ring-1 ring-white/10 px-3 py-2 text-white focus:ring-2 focus:ring-indigo-500 focus:outline-none text-sm' %>
            </div>
          </div>
        </div>

        <%# Save + Freeze %>
        <div class="flex flex-wrap items-center justify-between gap-3"
             data-controller="freeze"
             data-user-id="<%= user.id %>"
             data-freeze-reason-required-value="<%= t('.freeze.reason_required') %>"
             data-freeze-freezing-value="<%= t('.freeze.freezing') %>"
             data-freeze-error-value="<%= t('.freeze.error') %>"
             data-freeze-freeze-label-value="<%= t('.freeze.freeze') %>">

          <div class="flex gap-3 flex-wrap">
            <button type="button"
                    class="rounded-lg bg-red-600 px-4 py-2 text-sm font-medium text-white hover:bg-red-700 transition-colors"
                    data-action="click->freeze#open">
              <%= t('.freeze.freeze') %>
            </button>
            <div data-controller="unfreeze"
                 data-user-id="<%= user.id %>"
                 data-unfreeze-error-value="<%= t('.freeze.unfreeze_error') %>">
              <button type="button"
                      class="rounded-lg bg-gray-600 px-4 py-2 text-sm font-medium text-white hover:bg-gray-500 transition-colors"
                      data-action="click->unfreeze#unfreezeUser">
                <%= t('.freeze.unfreeze') %>
              </button>
            </div>
          </div>

          <%= f.submit t('admin.shared.save'),
                class: 'rounded-lg bg-indigo-600 px-6 py-2 text-sm font-semibold text-white hover:bg-indigo-700 transition-colors cursor-pointer' %>

          <%# Freeze modal %>
          <div id="freeze-modal" class="fixed inset-0 flex items-center justify-center bg-black/60 z-50 hidden">
            <div class="bg-gray-800 border border-gray-700 rounded-2xl p-6 w-full max-w-md mx-4 shadow-2xl">
              <h2 class="text-base font-semibold text-white mb-4"><%= t('.freeze.modal_title') %></h2>
              <div class="mb-4">
                <label class="block text-sm font-medium text-gray-300 mb-1"><%= t('.freeze.reason') %></label>
                <textarea id="freeze-reason"
                          class="w-full rounded-lg bg-gray-700 border-0 ring-1 ring-white/10 px-3 py-2 text-white placeholder-gray-400 focus:ring-2 focus:ring-indigo-500 focus:outline-none text-sm resize-none"
                          rows="3"
                          data-freeze-target="reason"
                          data-action="input->freeze#checkInput"
                          placeholder="<%= t('.freeze.reason_placeholder') %>"></textarea>
              </div>
              <div class="mb-5">
                <label class="block text-sm font-medium text-gray-300 mb-1"><%= t('.freeze.duration') %></label>
                <select id="freeze-duration"
                        class="w-full rounded-lg bg-gray-700 border-0 ring-1 ring-white/10 px-3 py-2 text-white focus:ring-2 focus:ring-indigo-500 focus:outline-none text-sm"
                        data-freeze-target="duration">
                  <option value="1.hour"><%= t('.freeze.durations.hour_1') %></option>
                  <option value="6.hours"><%= t('.freeze.durations.hours_6') %></option>
                  <option value="12.hours"><%= t('.freeze.durations.hours_12') %></option>
                  <option value="1.day"><%= t('.freeze.durations.day_1') %></option>
                  <option value="3.days"><%= t('.freeze.durations.days_3') %></option>
                  <option value="7.days"><%= t('.freeze.durations.days_7') %></option>
                  <option value="1.month"><%= t('.freeze.durations.month_1') %></option>
                  <option value="6.months"><%= t('.freeze.durations.months_6') %></option>
                  <option value="1.year"><%= t('.freeze.durations.year_1') %></option>
                  <option value="forever"><%= t('.freeze.durations.forever') %></option>
                </select>
              </div>
              <div class="flex justify-end gap-3">
                <button type="button"
                        class="rounded-lg bg-gray-700 px-4 py-2 text-sm font-medium text-gray-300 hover:bg-gray-600 transition-colors"
                        data-action="click->freeze#close">
                  <%= t('.freeze.cancel') %>
                </button>
                <button type="button"
                        class="rounded-lg bg-red-600 px-4 py-2 text-sm font-medium text-white hover:bg-red-700 transition-colors opacity-50 cursor-not-allowed"
                        data-freeze-target="submit"
                        data-action="click->freeze#submit"
                        disabled>
                  <%= t('.freeze.freeze') %>
                </button>
              </div>
            </div>
          </div>
        </div>

      <% end %>
    </div>

    <%# ===== USER EXPERIENCE SECTION ===== %>
    <div data-settings-target="section" data-section="user_experience" class="hidden">
      <div class="space-y-6">

        <%# Friends %>
        <div class="bg-gray-800 rounded-xl ring-1 ring-white/10 p-5">
          <h2 class="text-xs font-semibold uppercase tracking-widest text-gray-500 mb-4"><%= t('.friends.title') %></h2>
          <% if @user_friendships.any? %>
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
              <% @user_friendships.each do |friendship| %>
                <% friend = find_user_friend(friendship, @user) %>
                <% next unless friend %>
                <%= link_to profile_path_for(friend), class: "flex items-center gap-3 bg-gray-700/50 rounded-lg px-3 py-2 hover:bg-gray-700 transition-colors" do %>
                  <% if friend.avatar.attached? %>
                    <%= image_tag url_for(friend.avatar), class: "h-9 w-9 rounded-full object-cover shrink-0" %>
                  <% else %>
                    <%= image_tag 'empty-avatar.jpg', class: "h-9 w-9 rounded-full object-cover shrink-0" %>
                  <% end %>
                  <span class="text-sm text-white font-medium truncate"><%= friend.name %></span>
                <% end %>
              <% end %>
            </div>
          <% else %>
            <p class="text-sm text-gray-500"><%= t('.friends.empty') %></p>
          <% end %>
        </div>

        <%# Outgoing requests %>
        <div class="bg-gray-800 rounded-xl ring-1 ring-white/10 p-5">
          <h2 class="text-xs font-semibold uppercase tracking-widest text-gray-500 mb-4"><%= t('.requests.title') %></h2>
          <% if @user_sent_requests.any? %>
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
              <% @user_sent_requests.each do |req| %>
                <% next unless req.friend %>
                <%= link_to profile_path_for(req.friend), class: "flex items-center gap-3 bg-gray-700/50 rounded-lg px-3 py-2 hover:bg-gray-700 transition-colors" do %>
                  <% if req.friend.avatar.attached? %>
                    <%= image_tag url_for(req.friend.avatar), class: "h-9 w-9 rounded-full object-cover shrink-0" %>
                  <% else %>
                    <%= image_tag 'empty-avatar.jpg', class: "h-9 w-9 rounded-full object-cover shrink-0" %>
                  <% end %>
                  <span class="text-sm text-white font-medium truncate"><%= req.friend.name %></span>
                <% end %>
              <% end %>
            </div>
          <% else %>
            <p class="text-sm text-gray-500"><%= t('.requests.empty_outgoing') %></p>
          <% end %>
        </div>

        <%# Subscribers (incoming requests) %>
        <div class="bg-gray-800 rounded-xl ring-1 ring-white/10 p-5">
          <h2 class="text-xs font-semibold uppercase tracking-widest text-gray-500 mb-4"><%= t('.subscribers.title') %></h2>
          <% if @user_received_requests.any? %>
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
              <% @user_received_requests.each do |req| %>
                <% next unless req.user %>
                <%= link_to profile_path_for(req.user), class: "flex items-center gap-3 bg-gray-700/50 rounded-lg px-3 py-2 hover:bg-gray-700 transition-colors" do %>
                  <% if req.user.avatar.attached? %>
                    <%= image_tag url_for(req.user.avatar), class: "h-9 w-9 rounded-full object-cover shrink-0" %>
                  <% else %>
                    <%= image_tag 'empty-avatar.jpg', class: "h-9 w-9 rounded-full object-cover shrink-0" %>
                  <% end %>
                  <span class="text-sm text-white font-medium truncate"><%= req.user.name %></span>
                <% end %>
              <% end %>
            </div>
          <% else %>
            <p class="text-sm text-gray-500"><%= t('.subscribers.empty_incoming') %></p>
          <% end %>
        </div>

      </div>
    </div>

    <%# ===== GAMES SECTION ===== %>
    <div data-settings-target="section" data-section="games" class="hidden">
      <div class="bg-gray-800 rounded-xl ring-1 ring-white/10 p-5">
        <h2 class="text-xs font-semibold uppercase tracking-widest text-gray-500 mb-4"><%= t('.games_section.title') %></h2>
        <% if @user.games.any? %>
          <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4">
            <% @user.games.each do |game| %>
              <div class="group">
                <div class="aspect-video rounded-lg overflow-hidden bg-gray-700 mb-2">
                  <% if game.cover.attached? %>
                    <%= image_tag url_for(game.cover), alt: game.name, class: "w-full h-full object-cover group-hover:opacity-75 transition-opacity" %>
                  <% else %>
                    <%= image_tag 'empty-avatar.jpg', alt: game.name, class: "w-full h-full object-cover" %>
                  <% end %>
                </div>
                <p class="text-sm font-medium text-white truncate mb-1"><%= game.name %></p>
                <div class="flex gap-2">
                  <%= link_to t('admin.shared.edit'), edit_admin_game_path(game),
                        class: 'text-xs rounded bg-indigo-600/80 px-2 py-1 text-white hover:bg-indigo-600 transition-colors' %>
                  <%= link_to t('admin.shared.delete'), admin_game_path(game),
                        class: 'text-xs rounded bg-red-600/80 px-2 py-1 text-white hover:bg-red-600 transition-colors',
                        data: { turbo_method: :delete, turbo_confirm: t('admin.shared.confirm') } %>
                </div>
              </div>
            <% end %>
          </div>
        <% else %>
          <p class="text-sm text-gray-500"><%= t('.no_info') %></p>
        <% end %>
      </div>
    </div>

    <%# ===== JAMS SECTION ===== %>
    <div data-settings-target="section" data-section="jams" class="hidden">
      <div class="bg-gray-800 rounded-xl ring-1 ring-white/10 p-5">
        <h2 class="text-xs font-semibold uppercase tracking-widest text-gray-500 mb-4"><%= t('.jams_section.title') %></h2>
        <% if @user.jams.any? %>
          <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4">
            <% @user.jams.each do |jam| %>
              <div class="group">
                <div class="aspect-video rounded-lg overflow-hidden bg-gray-700 mb-2">
                  <% if jam.cover.attached? %>
                    <%= image_tag url_for(jam.cover), alt: jam.name, class: "w-full h-full object-cover group-hover:opacity-75 transition-opacity" %>
                  <% else %>
                    <%= image_tag 'empty-avatar.jpg', alt: jam.name, class: "w-full h-full object-cover" %>
                  <% end %>
                </div>
                <p class="text-sm font-medium text-white truncate mb-1"><%= jam.name %></p>
                <div class="flex gap-2">
                  <%= link_to t('admin.shared.edit'), edit_admin_jam_path(jam),
                        class: 'text-xs rounded bg-indigo-600/80 px-2 py-1 text-white hover:bg-indigo-600 transition-colors' %>
                  <%= link_to t('admin.shared.delete'), admin_jam_path(jam),
                        class: 'text-xs rounded bg-red-600/80 px-2 py-1 text-white hover:bg-red-600 transition-colors',
                        data: { turbo_method: :delete, turbo_confirm: t('admin.shared.confirm') } %>
                </div>
              </div>
            <% end %>
          </div>
        <% else %>
          <p class="text-sm text-gray-500"><%= t('.no_info') %></p>
        <% end %>
      </div>
    </div>

    <%# ===== SESSIONS SECTION ===== %>
    <div data-settings-target="section" data-section="sessions" class="hidden">
      <div class="bg-gray-800 rounded-xl ring-1 ring-white/10 p-5">
        <h2 class="text-xs font-semibold uppercase tracking-widest text-gray-500 mb-4"><%= t('.sessions_section.title') %></h2>
        <% if @user_sessions.any? %>
          <div class="space-y-2 mb-4">
            <% @user_sessions.each do |session| %>
              <div class="flex flex-col sm:flex-row sm:items-center justify-between bg-gray-700/50 rounded-lg px-4 py-3 gap-3">
                <div class="text-xs text-gray-300 space-y-0.5">
                  <p><span class="text-gray-500">ID:</span> <span class="font-mono"><%= session.session_id %></span></p>
                  <p><span class="text-gray-500">IP:</span> <%= session.ip_address %></p>
                  <p><span class="text-gray-500">Browser:</span> <%= session.browser || 'Unknown' %></p>
                  <p><span class="text-gray-500">Created:</span> <%= session.created_at.strftime('%d.%m.%Y %H:%M') %></p>
                </div>
                <%= form_tag logout_one_session_sessions_path(user: user, session_id: session.id), method: :post do %>
                  <%= submit_tag 'Log out', class: 'rounded-lg bg-red-600/80 px-3 py-1.5 text-xs font-medium text-white hover:bg-red-600 transition-colors cursor-pointer' %>
                <% end %>
              </div>
            <% end %>
          </div>
          <%= form_tag logout_all_sessions_sessions_path(user: user), method: :post do %>
            <%= submit_tag 'Log out all', class: 'rounded-lg bg-red-600 px-4 py-2 text-sm font-medium text-white hover:bg-red-700 transition-colors cursor-pointer' %>
          <% end %>
        <% else %>
          <p class="text-sm text-gray-500"><%= t('.sessions_section.empty') %></p>
        <% end %>
      </div>
    </div>

    <%# ===== NOTIFICATIONS SECTION ===== %>
    <div data-settings-target="section" data-section="notifications" class="hidden">
      <div class="bg-gray-800 rounded-xl ring-1 ring-white/10 p-5">
        <h2 class="text-xs font-semibold uppercase tracking-widest text-gray-500 mb-4"><%= t('.notifications_section.title') %></h2>
        <% if @user_notifications.any? %>
          <div class="space-y-2">
            <% @user_notifications.order(created_at: :desc).each do |notification| %>
              <% next unless notification.actor %>
              <div class="flex items-start gap-3 bg-gray-700/50 rounded-lg px-4 py-3">
                <% if notification.actor.avatar.attached? %>
                  <%= image_tag url_for(notification.actor.avatar), class: "h-9 w-9 rounded-full object-cover shrink-0" %>
                <% else %>
                  <%= image_tag 'empty-avatar.jpg', class: "h-9 w-9 rounded-full object-cover shrink-0" %>
                <% end %>
                <div class="min-w-0">
                  <p class="text-sm text-white">
                    <span class="font-medium"><%= notification.actor.name %></span>
                    <span class="text-gray-400 ml-1">
                      <% if notification.action == 'accepted_friendship' %>
                        <%= t('.notifications_section.accepted_friendship') %>
                      <% elsif notification.action == 'sent_friend_request' %>
                        <%= t('.notifications_section.sent_friend_request') %>
                      <% else %>
                        <%= notification.action %>
                      <% end %>
                    </span>
                  </p>
                  <p class="text-xs text-gray-500 mt-0.5"><%= notification.created_at.strftime("%d.%m.%Y %H:%M") %></p>
                </div>
              </div>
            <% end %>
          </div>
        <% else %>
          <p class="text-sm text-gray-500"><%= t('.notifications_section.empty') %></p>
        <% end %>
      </div>
    </div>

  </div>
</div>
