<div class="overflow-x-auto">
  <div class="flex flex-col md:flex-row items-center bg-gray-100 p-4 rounded-lg shadow-md mb-6 justify-between flex-wrap gap-4">
    <h2 class="text-xl font-bold text-gray-800"><%= t '.title' %></h2>
    <%= form_with url: admin_teams_path, method: :get, local: true, class: "flex items-center gap-2" do |f| %>
      <%= f.text_field :search, value: params[:search], placeholder: t('.search_label'),
          class: 'border border-gray-300 rounded-lg p-2 text-sm text-gray-700 focus:outline-none focus:ring-2 focus:ring-blue-500' %>
      <%= f.submit t('admin.shared.search'), class: 'bg-blue-500 text-white py-2 px-3 rounded text-sm hover:bg-blue-600' %>
      <%= link_to t('admin.shared.reset'), admin_teams_path, class: 'text-gray-500 hover:text-gray-700 text-sm' %>
    <% end %>
  </div>

  <% if @teams.any? %>
    <table class="min-w-full bg-white border border-gray-200">
      <thead>
        <tr class="bg-gray-100 text-gray-600 uppercase text-sm leading-normal">
          <th class="py-3 px-4 text-left">ID</th>
          <th class="py-3 px-4 text-left"><%= t 'teams.index.title' %></th>
          <th class="py-3 px-4 text-left"><%= t '.leader' %></th>
          <th class="py-3 px-4 text-left"><%= t '.members' %></th>
          <th class="py-3 px-4 text-left"><%= t '.created_at' %></th>
          <th class="py-3 px-4 text-left"></th>
        </tr>
      </thead>
      <tbody class="text-gray-600 text-sm">
        <% @teams.each do |team| %>
          <tr class="border-b border-gray-200 hover:bg-gray-50">
            <td class="py-3 px-4"><%= team.id %></td>
            <td class="py-3 px-4 font-medium">
              <%= link_to team.name, team_profile_path(team), class: 'text-blue-600 hover:underline', target: '_blank' %>
            </td>
            <td class="py-3 px-4"><%= team.leader.name %></td>
            <td class="py-3 px-4"><%= team.accepted_memberships.size %></td>
            <td class="py-3 px-4 text-gray-500"><%= team.created_at.strftime('%d.%m.%Y') %></td>
            <td class="py-3 px-4">
              <%= button_to t('admin.shared.delete'), admin_team_path(team), method: :delete,
                  data: { turbo_confirm: t('admin.shared.confirm') },
                  class: 'text-red-500 hover:underline text-sm bg-transparent border-0 cursor-pointer p-0' %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
    <%= render partial: 'helpers/pagy' %>
  <% else %>
    <p class="text-gray-500 m-8"><%= t '.not_found' %></p>
  <% end %>
</div>
