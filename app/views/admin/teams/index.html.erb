<div class="bg-gray-900 min-h-screen px-4 py-8 sm:px-6 lg:px-8">
  <div class="mx-auto max-w-7xl">
    <h1 class="text-2xl font-bold text-white mb-6"><%= t '.title' %></h1>

    <%= form_with url: admin_teams_path, method: :get, local: true, class: "mb-6" do |f| %>
      <div class="flex flex-wrap gap-3">
        <%= f.text_field :search, value: params[:search], placeholder: t('.search_label'),
                         class: "rounded-lg bg-gray-800 border-0 ring-1 ring-white/10 px-3 py-2 text-sm text-white
                                 placeholder-gray-500 focus:ring-2 focus:ring-indigo-500 focus:outline-none w-full max-w-xs" %>
        <%= f.submit t('admin.shared.search'),
                     class: "rounded-lg bg-indigo-600 px-4 py-2 text-sm font-medium text-white hover:bg-indigo-700 transition-colors cursor-pointer" %>
        <%= link_to t('admin.shared.reset'), admin_teams_path,
                    class: "rounded-lg bg-gray-700 px-4 py-2 text-sm font-medium text-gray-300 hover:bg-gray-600 transition-colors" %>
      </div>
    <% end %>

    <% if @teams.any? %>
      <div class="bg-gray-800 rounded-xl ring-1 ring-white/10 overflow-x-auto">
        <table class="min-w-full text-sm">
          <thead>
            <tr class="border-b border-white/10 text-gray-400 text-xs uppercase tracking-wider">
              <th class="py-3 px-4 text-left">ID</th>
              <th class="py-3 px-4 text-left"><%= t 'teams.index.title' %></th>
              <th class="py-3 px-4 text-left"><%= t '.leader' %></th>
              <th class="py-3 px-4 text-left"><%= t '.members' %></th>
              <th class="py-3 px-4 text-left"><%= t '.created_at' %></th>
              <th class="py-3 px-4"></th>
            </tr>
          </thead>
          <tbody class="divide-y divide-white/5 text-gray-300">
            <% @teams.each do |team| %>
              <tr class="hover:bg-white/5 transition-colors">
                <td class="py-3 px-4 text-gray-500 text-xs"><%= team.id %></td>
                <td class="py-3 px-4">
                  <%= link_to team.name, team_profile_path(team),
                              class: 'text-indigo-300 hover:text-indigo-200 hover:underline', target: '_blank' %>
                </td>
                <td class="py-3 px-4 text-gray-400"><%= team.leader.name %></td>
                <td class="py-3 px-4 text-gray-400"><%= team.accepted_memberships.size %></td>
                <td class="py-3 px-4 text-gray-500 text-xs"><%= team.created_at.strftime('%d.%m.%Y') %></td>
                <td class="py-3 px-4">
                  <%= button_to t('admin.shared.delete'), admin_team_path(team), method: :delete,
                                data: { turbo_confirm: t('admin.shared.confirm') },
                                class: 'rounded bg-red-600/80 text-white py-1 px-3 text-xs hover:bg-red-600 transition-colors' %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
      <div class="mt-4">
        <%= render partial: 'helpers/pagy' %>
      </div>
    <% else %>
      <div class="text-center py-16">
        <p class="text-gray-400"><%= t '.not_found' %></p>
      </div>
    <% end %>
  </div>
</div>
