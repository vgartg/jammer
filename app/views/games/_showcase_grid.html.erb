<div class="grid grid-cols-1 gap-x-6 gap-y-10 sm:grid-cols-2 lg:grid-cols-4 xl:gap-x-8">
  <% games.each do |game| %>
    <div>
      <div class="group relative">
        <%= link_to game_profile_path(game.id) do %>
          <% if game && game.cover.attached? %>
            <%= image_tag url_for(game.cover), alt: game.name,
                          class: "rounded-md bg-gray-200 w-full h-full lg:h-80 lg:w-full object-cover
                          object-center group-hover:opacity-75" %>
          <% else %>
            <div class="aspect-h-1 aspect-w-1 w-full overflow-hidden rounded-md bg-gray-200
                        lg:aspect-none group-hover:opacity-75 lg:h-80">
              <img src="https://via.placeholder.com/300" alt="<%= game.name %>" 4
                   class="h-full w-full object-cover object-center lg:h-full lg:w-full">
            </div>
          <% end %>
        <% end %>
        <% rating = game.overall_rating.to_f %>
        <% if rating > 0 %>
          <div class="absolute top-2 right-2 bg-white rounded-full px-2 py-1 shadow flex items-center space-x-1">
            <span class="text-sm font-bold text-gray-800"><%= rating %></span>
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-yellow-500" viewBox="0 0 20 20" fill="currentColor">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
            </svg>
          </div>
        <% end %>
      </div>

      <div class="mt-4 justify-between line-clamp-2">
        <div class="flex-1">
          <div class="flex items-center justify-between">
            <h3 class="text-sm text-gray-700 truncate">
              <%= link_to game_profile_path(game.id) do %>
                <%= game.name %>
              <% end %>
            </h3>
          </div>
          <p class="mt-1 text-sm text-gray-500 line-clamp-2">
            <%= game.description %>
          </p>
        </div>
        <div class="mt-4 text-gray-500 flex flex-wrap gap-2">
          <% game.tags.each do |tag| %>
            <span class="bg-gray-200 px-3 py-1 rounded-full text-sm font-medium text-gray-700"><%= tag.name %></span>
          <% end %>
        </div>
        <% if game.author.present? %>
          <a class="break-all" href="<%= user_profile_path(game.author) %>">
            <%= game.author.name %>
          </a>
        <% else %>
          <p>
            <%= t 'games.showcase.no_author' %>
          </p>
        <% end %>
      </div>
    </div>
  <% end %>
</div>
