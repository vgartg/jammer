<div class="max-w-4xl mx-auto px-4 py-16 sm:px-6 lg:px-8">
  <div class="mb-10">
    <h1 class="text-3xl font-bold text-gray-900"><%= t 'achievements.page_title' %></h1>
    <p class="mt-2 text-gray-600"><%= t 'achievements.page_subtitle' %></p>
  </div>

  <% tier_colors = { bronze: 'from-amber-400 to-amber-700', silver: 'from-gray-300 to-gray-500', gold: 'from-yellow-300 to-yellow-600', special: 'from-purple-400 to-purple-700' } %>
  <% tier_labels = { bronze: t('achievements.tiers.bronze'), silver: t('achievements.tiers.silver'), gold: t('achievements.tiers.gold'), special: t('achievements.tiers.special') } %>

  <% categories = @achievements.group_by { |_, cfg| cfg[:category] } %>
  <% categories.each do |category, items| %>
    <section class="mb-10">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        <% items.each do |key, cfg| %>
          <% tier = cfg[:tier] %>
          <% gradient = tier_colors[tier] || 'from-gray-400 to-gray-600' %>
          <div class="relative rounded-xl border border-gray-200 bg-white p-5 shadow-sm">
            <div class="flex items-center gap-4">
              <div class="h-16 w-16 rounded-full bg-gradient-to-br <%= gradient %> flex items-center justify-center shrink-0 shadow">
                <% if File.exist?(Rails.root.join("app/assets/images/achievements/#{key}.svg")) %>
                  <%= image_tag "achievements/#{key}.svg", class: "h-10 w-10", alt: key %>
                <% else %>
                  <svg class="h-8 w-8 text-white" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 18.75h-9m9 0a3 3 0 013 3h-15a3 3 0 013-3m9 0v-3.375c0-.621-.503-1.125-1.125-1.125h-.871M7.5 18.75v-3.375c0-.621.504-1.125 1.125-1.125h.872m5.007 0H9.497m5.007 0a7.454 7.454 0 01-.982-3.172M9.497 14.25a7.454 7.454 0 00.981-3.172M5.25 4.236c-.982.143-1.954.317-2.916.52A6.003 6.003 0 007.73 9.728M5.25 4.236V4.5c0 2.108.966 3.99 2.48 5.228M5.25 4.236V2.721C7.456 2.29 9.71 2 12 2c2.29 0 4.544.29 6.75.721v1.516M7.73 9.728a6.726 6.726 0 002.748 1.35m8.272-6.842V4.5c0 2.108-.966 3.99-2.48 5.228m2.48-5.492a46.32 46.32 0 012.916.52 6.003 6.003 0 01-5.395 4.972m0 0a6.726 6.726 0 01-2.749 1.35m0 0a6.772 6.772 0 01-3.044 0"/>
                  </svg>
                <% end %>
              </div>
              <div class="min-w-0">
                <p class="font-semibold text-gray-900"><%= t "achievements.#{key}.name" %></p>
                <p class="text-xs text-gray-500 mt-0.5"><%= t "achievements.tiers.#{tier}" %></p>
                <p class="text-sm text-gray-600 mt-1"><%= t "achievements.#{key}.description" %></p>
                <% if cfg[:threshold] %>
                  <p class="text-xs text-indigo-600 mt-1 font-medium">× <%= cfg[:threshold] %></p>
                <% end %>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    </section>
  <% end %>
</div>
