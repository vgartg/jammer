<turbo-frame id="achievements-sidebar-frame">
  <div class="px-4 py-5 space-y-6">

    <%# --- Earned badges --- %>
    <% if earned_keys.any? %>
      <div>
        <h3 class="text-xs font-semibold uppercase tracking-widest text-gray-500 mb-3"><%= t 'achievements.my_achievements' %></h3>
        <div class="grid grid-cols-4 gap-2">
          <% AchievementService::ACHIEVEMENTS.each do |key, cfg| %>
            <% next unless earned_keys.include?(key) %>
            <% next unless File.exist?(Rails.root.join("app/assets/images/achievements/#{key}.svg")) %>
            <%= link_to achievements_path, data: { turbo_frame: "_top" },
                  class: "flex flex-col items-center gap-1 rounded-lg bg-gray-800/60 hover:bg-gray-700/60 transition-colors p-2 text-center",
                  title: "#{t "achievements.#{key}.name"} — #{t "achievements.#{key}.description"}" do %>
              <%= image_tag "achievements/#{key}.svg",
                    alt: t("achievements.#{key}.name"),
                    class: "h-9 w-9 drop-shadow-md mx-auto" %>
              <span class="text-[10px] text-gray-300 leading-tight line-clamp-2 w-full">
                <%= t "achievements.#{key}.name" %>
              </span>
            <% end %>
          <% end %>
        </div>
      </div>
      <div class="border-t border-gray-700/50"></div>
    <% end %>

    <%# --- Progress bars by category --- %>
    <div>
      <h3 class="text-xs font-semibold uppercase tracking-widest text-gray-500 mb-3"><%= t 'achievements.page_subtitle' %></h3>
      <div class="space-y-4">
        <% progress.each do |entry| %>
          <% next if entry[:next_key].nil? && entry[:pct] == 100 && entry[:earned_keys].empty? %>
          <div>
            <div class="flex items-center justify-between mb-1">
              <span class="text-xs font-medium text-gray-300">
                <%= t("achievements.categories.#{entry[:category]}", default: entry[:category].to_s.humanize) %>
              </span>
              <span class="text-xs text-gray-500">
                <%= entry[:current] %> / <%= entry[:next_threshold] %>
              </span>
            </div>
            <div class="h-1.5 bg-gray-700 rounded-full overflow-hidden">
              <div class="h-full rounded-full transition-all duration-500
                          <%= entry[:next_tier] == :gold ? 'bg-yellow-400' :
                              entry[:next_tier] == :silver ? 'bg-gray-300' :
                              entry[:next_tier] == :bronze ? 'bg-amber-500' : 'bg-indigo-500' %>"
                   style="width: <%= entry[:pct] %>%"></div>
            </div>
            <% if entry[:next_key] %>
              <p class="mt-1 text-[11px] text-gray-500">
                <%= t "achievements.#{entry[:next_key]}.name" %> —
                <%= t "achievements.#{entry[:next_key]}.description" %>
              </p>
            <% else %>
              <p class="mt-1 text-[11px] text-indigo-400"><%= t 'achievements.tiers.gold' %> ✓</p>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>

    <div class="pt-2">
      <%= link_to t('achievements.all_achievements'), achievements_path,
            class: "block text-center text-xs text-indigo-400 hover:text-indigo-300 transition-colors",
            data: { turbo_frame: "_top" } %>
    </div>

  </div>
</turbo-frame>
