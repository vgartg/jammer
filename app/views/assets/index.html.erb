<div class="bg-gray-900 min-h-screen">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-12">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-8">
      <h1 class="text-3xl font-bold text-white"><%= t '.title' %></h1>
      <% if current_user %>
        <%= link_to t('.new_asset'), new_asset_path,
            class: "rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white hover:bg-indigo-500 transition-colors" %>
      <% end %>
    </div>

    <div class="mb-8">
      <%= form_with url: assets_path, method: :get, local: true, class: "flex flex-wrap gap-3" do |f| %>
        <%= f.text_field :search, value: params[:search], placeholder: t('.search_placeholder'),
            class: "flex-1 min-w-0 rounded-xl border-0 bg-gray-800 py-2.5 px-4 text-white placeholder-gray-500 ring-1 ring-inset ring-gray-700 focus:ring-2 focus:ring-indigo-500 sm:text-sm" %>
        <%= f.select :category, [['', '']] + Asset::CATEGORIES.map { |c| [t("assets.categories.#{c}"), c] },
            { selected: params[:category] },
            class: "rounded-xl border-0 bg-gray-800 py-2.5 px-3 text-white ring-1 ring-inset ring-gray-700 focus:ring-2 focus:ring-indigo-500 sm:text-sm" %>
        <%= f.submit t('.search_btn'), class: "rounded-xl bg-indigo-600 px-4 py-2.5 text-sm font-semibold text-white hover:bg-indigo-500 transition-colors cursor-pointer" %>
      <% end %>
    </div>

    <% if @assets.any? %>
      <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
        <% @assets.each do |asset| %>
          <a href="<%= asset_profile_path(asset) %>" class="group relative flex flex-col overflow-hidden rounded-2xl border border-gray-700/60 bg-gray-800 hover:border-gray-500/80 transition-all hover:shadow-xl hover:shadow-black/40">
            <div class="h-40 bg-gray-700 overflow-hidden">
              <% if asset.preview.attached? %>
                <%= image_tag url_for(asset.preview), alt: asset.title,
                    class: "h-full w-full object-cover group-hover:scale-105 transition-transform duration-300" %>
              <% else %>
                <div class="flex h-full items-center justify-center bg-gradient-to-br from-indigo-950/80 to-gray-800">
                  <svg class="h-14 w-14 text-indigo-700" fill="none" viewBox="0 0 24 24" stroke-width="1" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="m2.25 15.75 5.159-5.159a2.25 2.25 0 0 1 3.182 0l5.159 5.159m-1.5-1.5 1.409-1.409a2.25 2.25 0 0 1 3.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 0 0 1.5-1.5V6a1.5 1.5 0 0 0-1.5-1.5H3.75A1.5 1.5 0 0 0 2.25 6v12a1.5 1.5 0 0 0 1.5 1.5Zm10.5-11.25h.008v.008h-.008V8.25Zm.375 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Z"/>
                  </svg>
                </div>
              <% end %>
            </div>
            <div class="flex flex-1 flex-col p-4">
              <div class="flex items-start justify-between gap-2 mb-1">
                <h3 class="text-sm font-semibold text-white line-clamp-2 group-hover:text-indigo-400 transition-colors">
                  <%= asset.title %>
                </h3>
                <span class="shrink-0 rounded-full bg-indigo-900/40 border border-indigo-700/40 px-2 py-0.5 text-xs font-medium text-indigo-300">
                  <%= t "assets.categories.#{asset.category}" %>
                </span>
              </div>
              <% if asset.description.present? %>
                <p class="text-xs text-gray-400 line-clamp-2 mb-3"><%= asset.description %></p>
              <% end %>
              <div class="mt-auto flex items-center justify-between text-xs text-gray-500">
                <span class="flex items-center gap-1">
                  <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5M16.5 12 12 16.5m0 0L7.5 12m4.5 4.5V3"/>
                  </svg>
                  <%= asset.downloads_count %>
                </span>
                <% if asset.guide.attached? %>
                  <span class="flex items-center gap-1 text-green-500">
                    <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25"/>
                    </svg>
                    <%= t '.has_guide' %>
                  </span>
                <% end %>
                <span class="text-gray-500 truncate hover:text-gray-300 transition-colors"><%= asset.author.name %></span>
              </div>
            </div>
          </a>
        <% end %>
      </div>

      <div class="mt-8">
        <%== pagy_nav(@pagy) if @pagy.pages > 1 %>
      </div>
    <% else %>
      <div class="text-center py-20">
        <svg class="mx-auto h-12 w-12 text-gray-700" fill="none" viewBox="0 0 24 24" stroke-width="1" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="m2.25 15.75 5.159-5.159a2.25 2.25 0 0 1 3.182 0l5.159 5.159m-1.5-1.5 1.409-1.409a2.25 2.25 0 0 1 3.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 0 0 1.5-1.5V6a1.5 1.5 0 0 0-1.5-1.5H3.75A1.5 1.5 0 0 0 2.25 6v12a1.5 1.5 0 0 0 1.5 1.5Zm10.5-11.25h.008v.008h-.008V8.25Zm.375 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Z"/>
        </svg>
        <h3 class="mt-4 text-sm font-semibold text-gray-400"><%= t '.no_assets' %></h3>
        <% if current_user %>
          <p class="mt-1 text-sm text-gray-600"><%= t '.be_first' %></p>
          <div class="mt-4">
            <%= link_to t('.new_asset'), new_asset_path,
                class: "inline-flex items-center rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white hover:bg-indigo-500 transition-colors" %>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
