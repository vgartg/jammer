<div class="bg-gray-900 min-h-screen">
  <div class="pb-16 pt-6 sm:pb-24">
    <div class="mx-auto mt-8 max-w-2xl px-4 sm:px-6 lg:max-w-7xl lg:px-8">

      <%= link_to jam_show_projects_path(@jam),
            class: "inline-flex items-center gap-1.5 text-sm text-gray-400 hover:text-gray-200 transition-colors mb-6" do %>
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18"/>
        </svg>
        <%= @jam.name %>
      <% end %>

      <div class="flex justify-between items-center mb-8">
        <div>
          <h1 class="text-2xl font-medium text-white break-all"><%= @game.name %></h1>
          <p class="text-sm text-gray-400"><%= t('.jam_label') %> <%= @jam.name %></p>
        </div>

        <div class="text-right">
          <p class="text-sm text-gray-400"><%= t('.overall_score') %></p>
          <p id="overall_preview" class="text-2xl font-bold text-indigo-400">0.0</p>
        </div>
      </div>

      <div class="mt-8" data-controller="criteria-rating">
        <%= form_with url: jam_game_vote_path(@jam, @game), method: :post, data: { criteria_rating_target: "form" } do %>
          <input type="hidden" name="vote_type" value="<%= @vote_type %>">

          <div class="space-y-4">
            <% @criteria.each do |criterion| %>
              <% existing = @existing[criterion.title] %>

              <div class="rounded-xl border border-gray-700/60 p-5 bg-gray-800"
                   data-criteria-rating-target="criterionBlock"
                   data-criterion-id="<%= criterion.id %>">

                <div class="flex items-center justify-between mb-3">
                  <h2 class="text-base font-semibold text-white"><%= criterion.title %></h2>

                  <% if criterion.kind == "manually_ranked" %>
                    <div class="text-sm text-gray-500"><%= t('.one_vote') %></div>
                  <% else %>
                    <div class="text-sm text-gray-500">0..5</div>
                  <% end %>
                </div>

                <% if criterion.kind == "manually_ranked" %>
                  <% current_pick = @picks_by_criterion_id[criterion.id] %>

                  <turbo-frame id="jam_criterion_<%= criterion.id %>_pick_block">
                    <%= render partial: "jam_criterion_picks/pick_block",
                               locals: { jam: @jam, game: @game, criterion: criterion, current_pick: current_pick, vote_type: @vote_type } %>
                  </turbo-frame>

                  <input type="hidden" name="marks[<%= criterion.id %>]" value="0">
                  <input type="hidden" name="comments[<%= criterion.id %>]" value="">
                <% else %>
                  <div class="mt-2 flex items-center space-x-2"
                       data-criteria-rating-target="stars"
                       data-criterion-id="<%= criterion.id %>">
                    <% 5.times do |i| %>
                      <svg class="w-8 h-8 cursor-pointer transition-all"
                           data-action="mouseenter->criteria-rating#hover mouseleave->criteria-rating#leave click->criteria-rating#setRating"
                           data-rating="<%= i + 1 %>"
                           data-criterion-id="<%= criterion.id %>"
                           xmlns="http://www.w3.org/2000/svg"
                           viewBox="0 0 24 24"
                           fill="gray">
                        <polygon stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                 points="12 17.27 18.18 21 15.64 13.97 21 9.24 13.81 8.64 12 2 10.19 8.64 3 9.24 8.36 13.97 5.82 21 12 17.27"/>
                      </svg>
                    <% end %>
                  </div>

                  <div class="mt-3">
                    <textarea
                      class="w-full p-3 border border-gray-700 rounded-xl bg-gray-900 text-white focus:outline-none focus:ring-2 focus:ring-indigo-500 placeholder-gray-500 text-sm"
                      placeholder="<%= t('.comment_placeholder') %>"
                      rows="3"
                      maxlength="1000"
                      name="comments[<%= criterion.id %>]"
                      data-action="input->criteria-rating#recalcOverall"
                    ><%= existing&.comment.to_s %></textarea>
                  </div>

                  <input type="hidden"
                         name="marks[<%= criterion.id %>]"
                         value="<%= existing&.user_mark.to_f %>"
                         data-criteria-rating-target="markInput"
                         data-criterion-id="<%= criterion.id %>">
                <% end %>
              </div>
            <% end %>
          </div>

          <button type="submit"
                  class="mt-6 rounded-xl bg-indigo-600 px-6 py-2.5 text-sm font-semibold text-white hover:bg-indigo-500 transition-colors">
            <%= t('buttons.save') %>
          </button>
        <% end %>
      </div>

    </div>
  </div>
</div>
