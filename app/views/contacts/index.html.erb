<div class="max-w-4xl mx-auto px-4 py-16 sm:px-6 lg:px-8">
  <div class="mb-12">
    <h1 class="text-3xl font-bold text-gray-900"><%= t 'contacts.title' %></h1>
    <p class="mt-3 text-lg text-gray-600"><%= t 'contacts.subtitle' %></p>
  </div>

  <!-- Репозиторий -->
  <section class="mb-10">
    <h2 class="text-xl font-semibold text-gray-800 mb-4"><%= t 'contacts.github_title' %></h2>
    <a href="https://github.com/vgartg/jammer" target="_blank" rel="noopener noreferrer"
       class="inline-flex items-center gap-2 text-indigo-600 hover:underline font-medium">
      <svg class="w-5 h-5 fill-current" viewBox="0 0 20 20">
        <path fill-rule="evenodd"
              d="M10 0C4.477 0 0 4.484 0 10.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0110 4.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.203 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.942.359.31.678.921.678 1.856 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0020 10.017C20 4.484 15.522 0 10 0z"
              clip-rule="evenodd"/>
      </svg>
      github.com/vgartg/jammer
    </a>
  </section>

  <% github_card = ->(handle) do %>
    <a href="https://github.com/<%= handle %>" target="_blank" rel="noopener noreferrer"
       class="flex items-center gap-3 bg-white border border-gray-200 rounded-xl p-4 shadow-sm hover:border-indigo-300 transition-colors">
      <svg class="w-5 h-5 fill-current text-gray-700 shrink-0" viewBox="0 0 20 20">
        <path fill-rule="evenodd" d="M10 0C4.477 0 0 4.484 0 10.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0110 4.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.203 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.942.359.31.678.921.678 1.856 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0020 10.017C20 4.484 15.522 0 10 0z" clip-rule="evenodd"/>
      </svg>
      <span class="font-medium text-gray-900">@<%= handle %></span>
    </a>
  <% end %>

  <!-- Основатели -->
  <section class="mb-10">
    <h2 class="text-xl font-semibold text-gray-800 mb-4"><%= t 'contacts.founders_title' %></h2>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
      <% ['vgartg', 'Fiitovec99', 'Wolwer1nE'].each do |handle| %>
        <%= github_card.call(handle) %>
      <% end %>
    </div>
  </section>

  <!-- Текущие разработчики -->
  <section class="mb-10">
    <h2 class="text-xl font-semibold text-gray-800 mb-4"><%= t 'contacts.current_devs_title' %></h2>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
      <% ['vgartg', 'Fiitovec99', 'kalyuzhin'].each do |handle| %>
        <%= github_card.call(handle) %>
      <% end %>
    </div>
  </section>

  <!-- Также принимали участие в разработке продукта -->
  <section class="mb-10">
    <h2 class="text-xl font-semibold text-gray-800 mb-4"><%= t 'contacts.past_devs_title' %></h2>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
      <% ['TRCMKR', 'megavvve', 'danilgordienko', 'Shkobarev', 'privet-kak-dela'].each do |handle| %>
        <a href="https://github.com/<%= handle %>" target="_blank" rel="noopener noreferrer"
           class="flex items-center gap-3 bg-gray-50 border border-gray-200 rounded-xl p-4 shadow-sm hover:border-indigo-200 transition-colors">
          <svg class="w-5 h-5 fill-current text-gray-500 shrink-0" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10 0C4.477 0 0 4.484 0 10.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0110 4.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.203 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.942.359.31.678.921.678 1.856 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0020 10.017C20 4.484 15.522 0 10 0z" clip-rule="evenodd"/>
          </svg>
          <span class="font-medium text-gray-500">@<%= handle %></span>
        </a>
      <% end %>
    </div>
  </section>

  <!-- Контактная почта -->
  <section>
    <h2 class="text-xl font-semibold text-gray-800 mb-4"><%= t 'contacts.email_title' %></h2>
    <a href="mailto:jammer.website@internet.ru" class="text-indigo-600 hover:underline font-medium">
      jammer.website@internet.ru
    </a>
  </section>
</div>
