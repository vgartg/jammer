<div class="bg-gray-900 min-h-screen text-white">
  <div class="max-w-4xl mx-auto px-4 py-16 sm:px-6 lg:px-8">

    <div class="mb-12">
      <h1 class="text-3xl font-bold text-white"><%= t 'contacts.title' %></h1>
      <p class="mt-3 text-lg text-gray-400"><%= t 'contacts.subtitle' %></p>
      <span class="mt-3 inline-flex items-center gap-1.5 rounded-full bg-indigo-500/10 border border-indigo-500/30 px-3 py-1 text-xs font-medium text-indigo-400">
        <svg class="w-3 h-3 fill-current shrink-0" viewBox="0 0 20 20" aria-hidden="true">
          <path fill-rule="evenodd" d="M10 0C4.477 0 0 4.484 0 10.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0110 4.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.203 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.942.359.31.678.921.678 1.856 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0020 10.017C20 4.484 15.522 0 10 0z" clip-rule="evenodd"/>
        </svg>
        <%= t 'contacts.open_source_badge' %>
      </span>
    </div>

    <!-- Основатели -->
    <section class="mb-12">
      <h2 class="text-sm font-semibold uppercase tracking-wider text-gray-500 mb-4"><%= t 'contacts.founders_title' %></h2>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        <% ['vgartg', 'Fiitovec99', 'Wolwer1nE'].each do |handle| %>
          <a href="https://github.com/<%= handle %>" target="_blank" rel="noopener noreferrer"
             class="flex items-center gap-4 rounded-xl bg-indigo-600/20 border border-indigo-500/40
                    px-5 py-4 hover:bg-indigo-600/30 hover:border-indigo-400 transition-colors">
            <img src="https://github.com/<%= handle %>.png?size=48" alt="<%= handle %>"
                 class="w-12 h-12 rounded-full ring-2 ring-indigo-500 shrink-0"
                 onerror="this.src='/assets/empty-avatar.jpg'">
            <div>
              <p class="font-semibold text-white text-sm">@<%= handle %></p>
              <p class="text-xs text-indigo-300 mt-0.5"><%= t 'contacts.founders_title_short' %></p>
            </div>
          </a>
        <% end %>
      </div>
    </section>

    <!-- Текущие разработчики -->
    <section class="mb-12">
      <h2 class="text-sm font-semibold uppercase tracking-wider text-gray-500 mb-4"><%= t 'contacts.current_devs_title' %></h2>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
        <% ['vgartg', 'Fiitovec99', 'kalyuzhin'].each do |handle| %>
          <a href="https://github.com/<%= handle %>" target="_blank" rel="noopener noreferrer"
             class="flex items-center gap-3 rounded-xl bg-gray-800 border border-gray-700
                    px-4 py-3 hover:border-gray-500 transition-colors">
            <img src="https://github.com/<%= handle %>.png?size=40" alt="<%= handle %>"
                 class="w-10 h-10 rounded-full shrink-0"
                 onerror="this.src='/assets/empty-avatar.jpg'">
            <span class="font-medium text-gray-200 text-sm">@<%= handle %></span>
          </a>
        <% end %>
      </div>
    </section>

    <!-- Также принимали участие -->
    <section class="mb-12">
      <h2 class="text-sm font-semibold uppercase tracking-wider text-gray-500 mb-4"><%= t 'contacts.past_devs_title' %></h2>
      <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
        <% ['TRCMKR', 'megavvve', 'danilgordienko', 'Shkobarev', 'privet-kak-dela'].each do |handle| %>
          <a href="https://github.com/<%= handle %>" target="_blank" rel="noopener noreferrer"
             class="flex items-center gap-3 rounded-xl bg-gray-800/50 border border-gray-700/50
                    px-4 py-3 hover:border-gray-600 transition-colors">
            <svg class="w-4 h-4 fill-current text-gray-500 shrink-0" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 0C4.477 0 0 4.484 0 10.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0110 4.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.203 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.942.359.31.678.921.678 1.856 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0020 10.017C20 4.484 15.522 0 10 0z" clip-rule="evenodd"/>
            </svg>
            <span class="text-sm text-gray-400">@<%= handle %></span>
          </a>
        <% end %>
      </div>
    </section>

    <!-- Контактная почта -->
    <section>
      <h2 class="text-sm font-semibold uppercase tracking-wider text-gray-500 mb-4"><%= t 'contacts.email_title' %></h2>
      <a href="mailto:jammer.website@internet.ru"
         class="inline-flex items-center gap-2 text-indigo-400 hover:text-indigo-300 transition-colors font-medium">
        <svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/>
        </svg>
        jammer.website@internet.ru
      </a>
    </section>

  </div>
</div>
