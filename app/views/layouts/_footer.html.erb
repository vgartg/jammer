<footer class="bg-gray-900">
  <nav class="mx-auto flex max-w-7xl items-center justify-center p-6 lg:px-8" aria-label="Global">
    <div class="lg:flex lg:gap-x-12">
      <%= link_to t('layouts.header.home'), url_for(:root), class: "text-sm font-semibold leading-6 text-white" %>
      <%= link_to t('layouts.header.users'), url_for(:users), class: "text-sm font-semibold leading-6 text-white" %>
      <%= link_to t('layouts.header.games'), url_for(:games_showcase), class: "text-sm font-semibold leading-6 text-white" %>
      <%= link_to t('layouts.header.jams'), jams_showcase_path, class: "text-sm font-semibold leading-6 text-white" %>
    </div>
  </nav>
  <div class="flex flex-wrap justify-center items-center gap-4 px-4">
    <%= image_tag 'fsi_1.svg', class: "max-w-[45%] h-auto sm:max-w-xs" %>
    <%= image_tag 'fsi_2.svg', class: "max-w-[45%] h-auto sm:max-w-xs sm:w-1/4" %>
  </div>
  <div class="mx-auto flex max-w-7xl items-center justify-center p-6 lg:pl-72 lg:pr-32">
    <p class="text-sm font-semibold leading-6 text-white"><%= t 'layouts.footer.fsi_text' %></p>
  </div>
  <div class="mx-auto flex max-w-7xl items-center justify-center flex-col p-6 lg:px-8">
    <p class="text-sm font-semibold leading-6 text-white">Est. 2024. Jammer <%= APP_VERSION.to_s %><br></p>
    <p class="text-sm font-semibold leading-6 text-white">
      Email:
      <a href="mailto:jammer.website@internet.ru" class="text-sm font-semibold leading-6 text-white">jammer.website@internet.ru</a>
    </p>
    <p class="text-sm font-semibold leading-6 text-white"><%= t 'layouts.footer.copyright' %></p>
  </div>
</footer>