<footer class="bg-gray-900">
  <nav class="mx-auto max-w-7xl px-4 py-6 lg:px-8" aria-label="Global">
    <div class="flex flex-wrap justify-center gap-x-4 gap-y-3">
      <%= link_to t('layouts.header.dashboard'), news_path, class: "text-sm font-semibold leading-6 text-white whitespace-nowrap" %>
      <%= link_to t('layouts.header.users'), url_for(:users), class: "text-sm font-semibold leading-6 text-white whitespace-nowrap" %>
      <%= link_to t('layouts.header.games'), url_for(:games_showcase), class: "text-sm font-semibold leading-6 text-white whitespace-nowrap" %>
      <%= link_to t('layouts.header.jams'), jams_showcase_path, class: "text-sm font-semibold leading-6 text-white whitespace-nowrap" %>
      <%= link_to t('layouts.header.achievements'), achievements_path, class: "text-sm font-semibold leading-6 text-white whitespace-nowrap" %>
      <%= link_to t('layouts.footer.contacts'), contacts_path, class: "text-sm font-semibold leading-6 text-white whitespace-nowrap" %>
    </div>
  </nav>
  <div class="border-t border-gray-700 mx-auto max-w-7xl px-4 py-8 lg:px-8">
    <p class="text-center text-xs font-medium uppercase tracking-widest text-gray-400 mb-6"><%= t 'layouts.footer.supported_by' %></p>
    <div class="flex flex-wrap justify-center items-center gap-4 mb-6">
      <div class="rounded-xl bg-white px-5 py-3 shadow-sm">
        <%= image_tag 'fsi_1.svg', class: "h-10 w-auto", alt: t('layouts.footer.fsi_1_alt') %>
      </div>
      <div class="rounded-xl bg-gray-800 px-5 py-3 ring-1 ring-gray-700">
        <%= image_tag 'fsi_2.svg', class: "h-10 w-auto", alt: t('layouts.footer.fsi_2_alt') %>
      </div>
    </div>
    <p class="mx-auto max-w-2xl text-center text-xs leading-relaxed text-gray-400"><%= t 'layouts.footer.fsi_text' %></p>
  </div>
  <div class="mx-auto flex max-w-7xl items-center justify-center flex-wrap gap-3 py-4 px-6 lg:px-8">
    <a href="https://boosty.to/jammer_company/donate" target="_blank" rel="noopener noreferrer"
       class="inline-flex items-center gap-2 rounded-full bg-orange-500 px-5 py-2 text-sm font-semibold text-white shadow hover:bg-orange-400 transition-colors">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
      </svg>
      <%= t 'layouts.footer.support_boosty' %>
    </a>
    <a href="https://github.com/vgartg/jammer" target="_blank" rel="noopener noreferrer"
       class="inline-flex items-center gap-2 rounded-full bg-gray-700 px-5 py-2 text-sm font-semibold text-white shadow hover:bg-gray-600 transition-colors">
      <svg class="h-4 w-4 shrink-0 fill-current" viewBox="0 0 20 20" aria-hidden="true">
        <path fill-rule="evenodd" d="M10 0C4.477 0 0 4.484 0 10.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0110 4.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.203 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.942.359.31.678.921.678 1.856 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0020 10.017C20 4.484 15.522 0 10 0z" clip-rule="evenodd"/>
      </svg>
      <%= t 'layouts.footer.star_github' %>
    </a>
  </div>
  <div class="mx-auto flex max-w-7xl items-center justify-center flex-col p-6 lg:px-8">
    <p class="text-sm font-semibold leading-6 text-white">Est. 2024. Jammer <%= APP_VERSION.to_s %><br></p>
    <p class="text-sm font-semibold leading-6 text-white">
      Email:
      <a href="mailto:jammer.website@internet.ru" class="text-sm font-semibold leading-6 text-white">jammer.website@internet.ru</a>
    </p>
    <p class="text-sm font-semibold leading-6 text-white"><%= t 'layouts.footer.copyright' %></p>
  </div>
</footer>