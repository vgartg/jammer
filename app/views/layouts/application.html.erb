<!DOCTYPE html>
<html class="h-full bg-white">
<head>
  <title>Jammer</title>
  <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover">
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>

  <link rel="icon" type="image/png" href="<%= asset_path('whitewithouttitle.png') %>">
  <link rel="apple-touch-icon" href="<%= asset_path('whitewithouttitle.png') %>">

  <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
  <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>
</head>

<body class="h-full">
<%= render partial: 'layouts/header' %>
<% if @current_user %>
  <meta id="current-user" data-current-user="true"/>
  <div data-controller="dashboard achievements-panel" class="min-h-full">

    <%# ---- Achievements slide-over overlay ---- %>
    <div data-achievements-panel-target="overlay"
         class="hidden fixed inset-0 bg-black/50 z-[80]"
         data-action="click->achievements-panel#close"></div>

    <%# ---- Achievements slide-over panel ---- %>
    <div data-achievements-panel-target="panel"
         class="hidden fixed top-0 right-0 bottom-0 w-full sm:w-96 bg-gray-900 z-[90] shadow-2xl overflow-y-auto flex flex-col border-l border-gray-700">
      <div class="flex items-center justify-between px-4 py-4 border-b border-gray-700 flex-shrink-0">
        <h2 class="text-white font-semibold text-base"><%= t 'achievements.page_title' %></h2>
        <button type="button"
                data-action="click->achievements-panel#close"
                class="text-gray-400 hover:text-white transition-colors p-1 rounded">
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>
      <turbo-frame id="achievements-sidebar-frame"
                   data-src="<%= achievements_panel_path %>"
                   class="flex-1">
        <div class="flex items-center justify-center h-32">
          <div class="animate-spin h-5 w-5 border-2 border-indigo-500 border-t-transparent rounded-full"></div>
        </div>
      </turbo-frame>
    </div>

    <%# ---- Mobile sidebar ---- %>
    <div class="relative z-50 lg:hidden" role="dialog" aria-modal="true">
      <div class="hidden opacity-0 fixed inset-0 bg-gray-900/80"
           id="dashboard_gray_opacity_block" aria-hidden="true"></div>
      <div class="-translate-x-full fixed inset-0 flex" id="dashboard_left_mobile_block">
        <div class="relative mr-16 flex w-full max-w-xs flex-1">
          <div class="absolute left-full top-0 flex w-16 justify-center pt-5">
            <button type="button" class="-m-2.5 p-2.5" data-action="click->dashboard#closeMobileMenu">
              <svg class="h-6 w-6 text-white" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
              </svg>
            </button>
          </div>
          <div class="flex grow flex-col gap-y-5 overflow-y-auto bg-gray-900 px-6 pb-4 ring-1 ring-white/10">
            <div class="flex h-4 shrink-0 items-center"></div>
            <div class="logo">
              <%= link_to root_path do %>
                <%= image_tag 'whitewithoutwall.png', alt: t('layouts.application.logo_alt'), width: '100', height: 'auto' %>
              <% end %>
            </div>
            <nav class="flex flex-1 flex-col">
              <ul role="list" class="flex flex-1 flex-col gap-y-7">
                <li>
                  <ul role="list" class="-mx-2 space-y-1">

                    <%# Dashboard %>
                    <li class="group rounded-md text-sm font-semibold leading-6 hover:bg-gray-800 text-gray-400 cursor-pointer">
                      <%= link_to news_path, class: "group flex gap-x-3 items-center rounded-md p-2 text-sm font-semibold leading-6 text-gray-400 w-full", data: { action: "click->dashboard#closeMobileMenu" } do %>
                        <svg class="h-6 w-6 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25"/>
                        </svg>
                        <%= t 'layouts.header.dashboard' %>
                      <% end %>
                    </li>

                    <%# Friends %>
                    <li class="group rounded-md text-sm font-semibold leading-6 hover:bg-gray-800 text-gray-400 cursor-pointer">
                      <%= link_to friends_path, class: "group flex gap-x-3 items-center rounded-md p-2 text-sm font-semibold leading-6 text-gray-400 w-full", data: { action: "click->dashboard#closeMobileMenu" } do %>
                        <svg class="h-6 w-6 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z"/>
                        </svg>
                        <%= t 'friendships.index.title' %>
                      <% end %>
                    </li>

                    <%# Teams %>
                    <li class="group rounded-md text-sm font-semibold leading-6 hover:bg-gray-800 text-gray-400 cursor-pointer">
                      <%= link_to teams_path, class: "group flex gap-x-3 items-center rounded-md p-2 text-sm font-semibold leading-6 text-gray-400 w-full", data: { action: "click->dashboard#closeMobileMenu" } do %>
                        <svg class="h-6 w-6 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 0 0 3.741-.479 3 3 0 0 0-4.682-2.72m.94 3.198.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0 1 12 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 0 1 6 18.719m12 0a5.971 5.971 0 0 0-.941-3.197m0 0A5.995 5.995 0 0 0 12 12.75a5.995 5.995 0 0 0-5.058 2.772m0 0a3 3 0 0 0-4.681 2.72 8.986 8.986 0 0 0 3.74.477m.94-3.197a5.971 5.971 0 0 0-.94 3.197M15 6.75a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm6 3a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Zm-13.5 0a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Z"/>
                        </svg>
                        <%= t 'layouts.header.teams' %>
                      <% end %>
                    </li>

                    <%# Games %>
                    <li class="group rounded-md text-sm font-semibold leading-6 hover:bg-gray-800 text-gray-400 cursor-pointer">
                      <%= link_to games_showcase_path, class: "group flex gap-x-3 items-center rounded-md p-2 text-sm font-semibold leading-6 text-gray-400 w-full", data: { action: "click->dashboard#closeMobileMenu" } do %>
                        <svg class="h-6 w-6 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12.75V12A2.25 2.25 0 014.5 9.75h15A2.25 2.25 0 0121.75 12v.75m-8.69-6.44l-2.12-2.12a1.5 1.5 0 00-1.061-.44H4.5A2.25 2.25 0 002.25 6v12a2.25 2.25 0 002.25 2.25h15A2.25 2.25 0 0021.75 18V9a2.25 2.25 0 00-2.25-2.25h-5.379a1.5 1.5 0 01-1.06-.44z"/>
                        </svg>
                        <%= t 'layouts.header.games' %>
                      <% end %>
                    </li>

                    <%# Jams %>
                    <li class="group rounded-md text-sm font-semibold leading-6 hover:bg-gray-800 text-gray-400 cursor-pointer">
                      <%= link_to jams_showcase_path, class: "group flex gap-x-3 items-center rounded-md p-2 text-sm font-semibold leading-6 text-gray-400 w-full", data: { action: "click->dashboard#closeMobileMenu" } do %>
                        <svg class="h-6 w-6 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5"/>
                        </svg>
                        <%= t 'layouts.header.jams' %>
                      <% end %>
                    </li>

                    <%# Assets %>
                    <li class="group rounded-md text-sm font-semibold leading-6 hover:bg-gray-800 text-gray-400 cursor-pointer">
                      <%= link_to assets_path, class: "group flex gap-x-3 items-center rounded-md p-2 text-sm font-semibold leading-6 text-gray-400 w-full", data: { action: "click->dashboard#closeMobileMenu" } do %>
                        <svg class="h-6 w-6 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
                          <path stroke-linecap="round" stroke-linejoin="round" d="m2.25 15.75 5.159-5.159a2.25 2.25 0 0 1 3.182 0l5.159 5.159m-1.5-1.5 1.409-1.409a2.25 2.25 0 0 1 3.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 0 0 1.5-1.5V6a1.5 1.5 0 0 0-1.5-1.5H3.75A1.5 1.5 0 0 0 2.25 6v12a1.5 1.5 0 0 0 1.5 1.5Zm10.5-11.25h.008v.008h-.008V8.25Zm.375 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Z"/>
                        </svg>
                        <%= t 'layouts.header.assets' %>
                      <% end %>
                    </li>

                    <%# Achievements — opens panel %>
                    <li class="group rounded-md text-sm font-semibold leading-6 hover:bg-gray-800 text-gray-400 cursor-pointer">
                      <button type="button"
                              class="group flex gap-x-3 items-center rounded-md p-2 text-sm font-semibold leading-6 text-gray-400 w-full"
                              data-action="click->achievements-panel#open click->dashboard#closeMobileMenu">
                        <svg class="h-6 w-6 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 18.75h-9m9 0a3 3 0 0 1 3 3h-15a3 3 0 0 1 3-3m9 0v-3.375c0-.621-.503-1.125-1.125-1.125h-.871M7.5 18.75v-3.375c0-.621.504-1.125 1.125-1.125h.872m5.007 0H9.497m5.007 0a7.454 7.454 0 0 1-.982-3.172M9.497 14.25a7.454 7.454 0 0 0 .981-3.172M5.25 4.236c-.982.143-1.954.317-2.916.52A6.003 6.003 0 0 0 7.73 9.728M5.25 4.236V4.5c0 2.108.966 3.99 2.48 5.228M5.25 4.236V2.721C7.456 2.41 9.71 2.25 12 2.25c2.291 0 4.545.16 6.75.47v1.516M7.73 9.728a6.726 6.726 0 0 0 2.748 1.35m8.272-6.842V4.5c0 2.108-.966 3.99-2.48 5.228m2.48-5.492a46.32 46.32 0 0 1 2.916.52 6.003 6.003 0 0 1-5.395 4.972m0 0a6.726 6.726 0 0 1-2.749 1.35m0 0a6.772 6.772 0 0 1-3.044 0"/>
                        </svg>
                        <%= t 'achievements.page_title' %>
                      </button>
                    </li>

                    <%# Contacts %>
                    <li class="group rounded-md text-sm font-semibold leading-6 hover:bg-gray-800 text-gray-400 cursor-pointer">
                      <%= link_to contacts_path, class: "group flex gap-x-3 items-center rounded-md p-2 text-sm font-semibold leading-6 text-gray-400 w-full", data: { action: "click->dashboard#closeMobileMenu" } do %>
                        <svg class="h-6 w-6 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M11.25 11.25l.041-.02a.75.75 0 011.063.852l-.708 2.836a.75.75 0 001.063.853l.041-.021M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9-3.75h.008v.008H12V8.25z"/>
                        </svg>
                        <%= t 'layouts.footer.contacts' %>
                      <% end %>
                    </li>

                    <%# Admin panel %>
                    <% if @current_user.role == 'admin' %>
                      <li class="group rounded-md text-sm font-semibold leading-6 hover:bg-gray-800 text-gray-400 cursor-pointer">
                        <%= link_to '/admin', class: "group flex gap-x-3 items-center rounded-md p-2 text-sm font-semibold leading-6 text-gray-400 w-full", data: { action: "click->dashboard#closeMobileMenu" } do %>
                          <svg class="h-6 w-6 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 6a7.5 7.5 0 107.5 7.5h-7.5V6z"/>
                            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 10.5H21A7.5 7.5 0 0013.5 3v7.5z"/>
                          </svg>
                          <%= t 'layouts.application.admin_panel' %>
                        <% end %>
                      </li>
                    <% end %>

                    <%# Moderator panel %>
                    <% if @current_user.role == 'moderator' %>
                      <li class="group rounded-md text-sm font-semibold leading-6 hover:bg-gray-800 text-gray-400 cursor-pointer">
                        <%= link_to '/moderator', class: "group flex gap-x-3 items-center rounded-md p-2 text-sm font-semibold leading-6 text-gray-400 w-full", data: { action: "click->dashboard#closeMobileMenu" } do %>
                          <svg class="h-6 w-6 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 6a7.5 7.5 0 107.5 7.5h-7.5V6z"/>
                            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 10.5H21A7.5 7.5 0 0013.5 3v7.5z"/>
                          </svg>
                          <%= t 'layouts.application.moderator_panel' %>
                        <% end %>
                      </li>
                    <% end %>

                  </ul>
                </li>

                <%# Bottom — Notifications + Settings %>
                <li class="mt-auto space-y-1 -mx-2">
                  <div class="group rounded-md text-sm font-semibold leading-6 hover:bg-gray-800 text-gray-400 cursor-pointer">
                    <%= link_to notifications_path, class: "group flex gap-x-3 items-center rounded-md p-2 text-sm font-semibold leading-6 text-gray-400 w-full", data: { action: "click->dashboard#closeMobileMenu" } do %>
                      <svg class="h-6 w-6 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M14.857 17.082a23.848 23.848 0 005.454-1.31A8.967 8.967 0 0118 9.75v-.7V9A6 6 0 006 9v.75a8.967 8.967 0 01-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 01-5.714 0m5.714 0a3 3 0 11-5.714 0"/>
                      </svg>
                      <%= t 'layouts.left-menu.notifications' %>
                    <% end %>
                  </div>
                  <div class="group rounded-md text-sm font-semibold leading-6 hover:bg-gray-800 text-gray-400 cursor-pointer">
                    <%= link_to settings_path, class: "group flex gap-x-3 items-center rounded-md p-2 text-sm font-semibold leading-6 text-gray-400 w-full", data: { action: "click->dashboard#closeMobileMenu" } do %>
                      <svg class="h-6 w-6 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.324.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 011.37.49l1.296 2.247a1.125 1.125 0 01-.26 1.431l-1.003.827c-.293.24-.438.613-.431.992a6.759 6.759 0 010 .255c-.007.378.138.75.43.99l1.005.828c.424.35.534.954.26 1.43l-1.298 2.247a1.125 1.125 0 01-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.57 6.57 0 01-.22.128c-.331.183-.581.495-.644.869l-.213 1.28c-.09.543-.56.941-1.11.941h-2.594c-.55 0-1.02-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 01-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 01-1.369-.49l-1.297-2.247a1.125 1.125 0 01.26-1.431l1.004-.827c.292-.24.437-.613.43-.992a6.932 6.932 0 010-.255c.007-.378-.138-.75-.43-.99l-1.004-.828a1.125 1.125 0 01-.26-1.43l1.297-2.247a1.125 1.125 0 011.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.087.22-.128.332-.183.582-.495.644-.869l.214-1.281z"/>
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                      </svg>
                      <%= t 'layouts.left-menu.settings' %>
                    <% end %>
                  </div>
                </li>

              </ul>
            </nav>
          </div>
        </div>
      </div>
    </div>

    <%# ---- Desktop sidebar ---- %>
    <div class="hidden lg:fixed lg:inset-y-0 lg:z-50 lg:flex lg:w-72 lg:flex-col">
      <div class="flex grow flex-col gap-y-5 overflow-y-auto bg-gray-900 px-6 pb-4">
        <div class="flex h-4 shrink-0 items-center"></div>
        <div class="logo">
          <%= link_to root_path do %>
            <%= image_tag 'whitewithoutwall.png', alt: t('layouts.application.logo_alt'), width: '100', height: 'auto' %>
          <% end %>
        </div>
        <nav class="flex flex-1 flex-col">
          <ul role="list" class="flex flex-1 flex-col gap-y-7">
            <li>
              <ul role="list" class="-mx-2 space-y-1">

                <%# Dashboard %>
                <li class="group rounded-md text-sm font-semibold leading-6 text-gray-400 cursor-pointer hover:bg-gray-800">
                  <%= link_to news_path, class: "group flex gap-x-3 items-center rounded-md p-2 text-sm font-semibold leading-6 text-gray-400 w-full" do %>
                    <svg class="h-6 w-6 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25"/>
                    </svg>
                    <%= t 'layouts.header.dashboard' %>
                  <% end %>
                </li>

                <%# Friends %>
                <li class="group rounded-md text-sm font-semibold leading-6 text-gray-400 cursor-pointer hover:bg-gray-800">
                  <%= link_to friends_path, class: "group flex gap-x-3 items-center rounded-md p-2 text-sm font-semibold leading-6 text-gray-400 w-full" do %>
                    <svg class="h-6 w-6 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z"/>
                    </svg>
                    <%= t 'friendships.index.title' %>
                  <% end %>
                </li>

                <%# Teams %>
                <li class="group rounded-md text-sm font-semibold leading-6 text-gray-400 cursor-pointer hover:bg-gray-800">
                  <%= link_to teams_path, class: "group flex gap-x-3 items-center rounded-md p-2 text-sm font-semibold leading-6 text-gray-400 w-full" do %>
                    <svg class="h-6 w-6 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 0 0 3.741-.479 3 3 0 0 0-4.682-2.72m.94 3.198.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0 1 12 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 0 1 6 18.719m12 0a5.971 5.971 0 0 0-.941-3.197m0 0A5.995 5.995 0 0 0 12 12.75a5.995 5.995 0 0 0-5.058 2.772m0 0a3 3 0 0 0-4.681 2.72 8.986 8.986 0 0 0 3.74.477m.94-3.197a5.971 5.971 0 0 0-.94 3.197M15 6.75a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm6 3a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Zm-13.5 0a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Z"/>
                    </svg>
                    <%= t 'layouts.header.teams' %>
                  <% end %>
                </li>

                <%# Games %>
                <li class="group rounded-md text-sm font-semibold leading-6 text-gray-400 cursor-pointer hover:bg-gray-800">
                  <%= link_to games_showcase_path, class: "group flex gap-x-3 items-center rounded-md p-2 text-sm font-semibold leading-6 text-gray-400 w-full" do %>
                    <svg class="h-6 w-6 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12.75V12A2.25 2.25 0 014.5 9.75h15A2.25 2.25 0 0121.75 12v.75m-8.69-6.44l-2.12-2.12a1.5 1.5 0 00-1.061-.44H4.5A2.25 2.25 0 002.25 6v12a2.25 2.25 0 002.25 2.25h15A2.25 2.25 0 0021.75 18V9a2.25 2.25 0 00-2.25-2.25h-5.379a1.5 1.5 0 01-1.06-.44z"/>
                    </svg>
                    <%= t 'layouts.header.games' %>
                  <% end %>
                </li>

                <%# Jams %>
                <li class="group rounded-md text-sm font-semibold leading-6 text-gray-400 cursor-pointer hover:bg-gray-800">
                  <%= link_to jams_showcase_path, class: "group flex gap-x-3 items-center rounded-md p-2 text-sm font-semibold leading-6 text-gray-400 w-full" do %>
                    <svg class="h-6 w-6 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5"/>
                    </svg>
                    <%= t 'layouts.header.jams' %>
                  <% end %>
                </li>

                <%# Assets %>
                <li class="group rounded-md text-sm font-semibold leading-6 text-gray-400 cursor-pointer hover:bg-gray-800">
                  <%= link_to assets_path, class: "group flex gap-x-3 items-center rounded-md p-2 text-sm font-semibold leading-6 text-gray-400 w-full" do %>
                    <svg class="h-6 w-6 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="m2.25 15.75 5.159-5.159a2.25 2.25 0 0 1 3.182 0l5.159 5.159m-1.5-1.5 1.409-1.409a2.25 2.25 0 0 1 3.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 0 0 1.5-1.5V6a1.5 1.5 0 0 0-1.5-1.5H3.75A1.5 1.5 0 0 0 2.25 6v12a1.5 1.5 0 0 0 1.5 1.5Zm10.5-11.25h.008v.008h-.008V8.25Zm.375 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Z"/>
                    </svg>
                    <%= t 'layouts.header.assets' %>
                  <% end %>
                </li>

                <%# Achievements — opens slide panel %>
                <li class="group rounded-md text-sm font-semibold leading-6 text-gray-400 cursor-pointer hover:bg-gray-800">
                  <button type="button"
                          class="group flex gap-x-3 items-center rounded-md p-2 text-sm font-semibold leading-6 text-gray-400 w-full"
                          data-action="click->achievements-panel#open">
                    <svg class="h-6 w-6 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 18.75h-9m9 0a3 3 0 0 1 3 3h-15a3 3 0 0 1 3-3m9 0v-3.375c0-.621-.503-1.125-1.125-1.125h-.871M7.5 18.75v-3.375c0-.621.504-1.125 1.125-1.125h.872m5.007 0H9.497m5.007 0a7.454 7.454 0 0 1-.982-3.172M9.497 14.25a7.454 7.454 0 0 0 .981-3.172M5.25 4.236c-.982.143-1.954.317-2.916.52A6.003 6.003 0 0 0 7.73 9.728M5.25 4.236V4.5c0 2.108.966 3.99 2.48 5.228M5.25 4.236V2.721C7.456 2.41 9.71 2.25 12 2.25c2.291 0 4.545.16 6.75.47v1.516M7.73 9.728a6.726 6.726 0 0 0 2.748 1.35m8.272-6.842V4.5c0 2.108-.966 3.99-2.48 5.228m2.48-5.492a46.32 46.32 0 0 1 2.916.52 6.003 6.003 0 0 1-5.395 4.972m0 0a6.726 6.726 0 0 1-2.749 1.35m0 0a6.772 6.772 0 0 1-3.044 0"/>
                    </svg>
                    <%= t 'achievements.page_title' %>
                  </button>
                </li>

                <%# Contacts %>
                <li class="group rounded-md text-sm font-semibold leading-6 text-gray-400 cursor-pointer hover:bg-gray-800">
                  <%= link_to contacts_path, class: "group flex gap-x-3 items-center rounded-md p-2 text-sm font-semibold leading-6 text-gray-400 w-full" do %>
                    <svg class="h-6 w-6 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M11.25 11.25l.041-.02a.75.75 0 011.063.852l-.708 2.836a.75.75 0 001.063.853l.041-.021M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9-3.75h.008v.008H12V8.25z"/>
                    </svg>
                    <%= t 'layouts.footer.contacts' %>
                  <% end %>
                </li>

                <%# Admin panel %>
                <% if @current_user.role == 'admin' %>
                  <li class="group rounded-md text-sm font-semibold leading-6 text-gray-400 cursor-pointer hover:bg-gray-800">
                    <%= link_to '/admin', class: "group flex gap-x-3 items-center rounded-md p-2 text-sm font-semibold leading-6 text-gray-400 w-full" do %>
                      <svg class="h-6 w-6 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 6a7.5 7.5 0 107.5 7.5h-7.5V6z"/>
                        <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 10.5H21A7.5 7.5 0 0013.5 3v7.5z"/>
                      </svg>
                      <%= t 'layouts.application.admin_panel' %>
                    <% end %>
                  </li>
                <% end %>

                <%# Moderator panel %>
                <% if @current_user.role == 'moderator' %>
                  <li class="group rounded-md text-sm font-semibold leading-6 text-gray-400 cursor-pointer hover:bg-gray-800">
                    <%= link_to '/moderator', class: "group flex gap-x-3 items-center rounded-md p-2 text-sm font-semibold leading-6 text-gray-400 w-full" do %>
                      <svg class="h-6 w-6 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 6a7.5 7.5 0 107.5 7.5h-7.5V6z"/>
                        <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 10.5H21A7.5 7.5 0 0013.5 3v7.5z"/>
                      </svg>
                      <%= t 'layouts.application.moderator_panel' %>
                    <% end %>
                  </li>
                <% end %>

              </ul>
            </li>

            <%# Bottom — Notifications + Settings %>
            <li class="mt-auto space-y-1 -mx-2">
              <div class="group rounded-md text-sm font-semibold leading-6 text-gray-400 cursor-pointer hover:bg-gray-800">
                <%= link_to notifications_path, class: "group flex gap-x-3 items-center rounded-md p-2 text-sm font-semibold leading-6 text-gray-400 w-full" do %>
                  <svg class="h-6 w-6 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M14.857 17.082a23.848 23.848 0 005.454-1.31A8.967 8.967 0 0118 9.75v-.7V9A6 6 0 006 9v.75a8.967 8.967 0 01-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 01-5.714 0m5.714 0a3 3 0 11-5.714 0"/>
                  </svg>
                  <%= t 'layouts.left-menu.notifications' %>
                <% end %>
              </div>
              <div class="group rounded-md text-sm font-semibold leading-6 text-gray-400 cursor-pointer hover:bg-gray-800">
                <%= link_to settings_path, class: "group flex gap-x-3 items-center rounded-md p-2 text-sm font-semibold leading-6 text-gray-400 w-full" do %>
                  <svg class="h-6 w-6 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.324.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 011.37.49l1.296 2.247a1.125 1.125 0 01-.26 1.431l-1.003.827c-.293.24-.438.613-.431.992a6.759 6.759 0 010 .255c-.007.378.138.75.43.99l1.005.828c.424.35.534.954.26 1.43l-1.298 2.247a1.125 1.125 0 01-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.57 6.57 0 01-.22.128c-.331.183-.581.495-.644.869l-.213 1.28c-.09.543-.56.941-1.11.941h-2.594c-.55 0-1.02-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 01-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 01-1.369-.49l-1.297-2.247a1.125 1.125 0 01.26-1.431l1.004-.827c.292-.24.437-.613.43-.992a6.932 6.932 0 010-.255c.007-.378-.138-.75-.43-.99l-1.004-.828a1.125 1.125 0 01-.26-1.43l1.297-2.247a1.125 1.125 0 011.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.087.22-.128.332-.183.582-.495.644-.869l.214-1.281z"/>
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                  </svg>
                  <%= t 'layouts.left-menu.settings' %>
                <% end %>
              </div>
            </li>

          </ul>
        </nav>
      </div>
    </div>

    <div class="lg:pl-72">
      <main>
        <%= render partial: 'helpers/gray_search' %>
        <div>
          <%= yield %>
        </div>
      </main>
    </div>
  </div>
<% else %>
  <meta id="current-user" data-current-user="false" />
  <main role="main" class="min-h-full">
    <%= yield %>
  </main>
<% end %>
<turbo-frame id="flash_notices">
  <%= render partial: 'helpers/good_notice' %>
  <%= render partial: 'helpers/bad_notice' %>
</turbo-frame>
<%= render partial: 'layouts/footer' %>
</body>
</html>
