<% if @current_user&.needs_password? %>
  <div class="bg-amber-500 px-4 py-3 sm:px-6" role="alert">
    <div class="flex items-start gap-3 max-w-7xl mx-auto">
      <svg class="h-5 w-5 text-amber-900 shrink-0 mt-0.5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
        <path fill-rule="evenodd" d="M8.485 2.495c.673-1.167 2.357-1.167 3.03 0l6.28 10.875c.673 1.167-.17 2.625-1.516 2.625H3.72c-1.347 0-2.189-1.458-1.515-2.625L8.485 2.495zM10 5a.75.75 0 01.75.75v3.5a.75.75 0 01-1.5 0v-3.5A.75.75 0 0110 5zm0 9a1 1 0 100-2 1 1 0 000 2z" clip-rule="evenodd"/>
      </svg>
      <div class="flex-1 min-w-0">
        <p class="text-sm font-semibold text-amber-900"><%= t 'layouts.oauth_no_password_banner.title' %></p>
        <p class="mt-0.5 text-sm text-amber-800"><%= t 'layouts.oauth_no_password_banner.body' %></p>
      </div>
      <%= link_to t('layouts.oauth_no_password_banner.action'),
                  settings_path(anchor: 'security-section'),
                  class: 'shrink-0 rounded-md bg-amber-900 px-3 py-1.5 text-sm font-semibold text-white
                          hover:bg-amber-800 transition-colors' %>
    </div>
  </div>
<% end %>
