<div class="flex min-h-full flex-col justify-center bg-gray-900 py-12 sm:px-6 lg:px-8">
  <div class="sm:mx-auto sm:w-full sm:max-w-md">
    <div class="flex flex-col items-center">
      <%= image_tag 'whitewithouttitle.png', class: "h-16 w-auto scale-150" %>
      <h2 class="mt-6 text-center text-2xl font-bold leading-9 tracking-tight text-white"><%= t '.title' %></h2>
    </div>
  </div>
  <div class="mt-10 sm:mx-auto sm:w-full sm:max-w-[480px]">
    <div class="bg-gray-800 px-6 py-12 shadow sm:rounded-lg sm:px-12 ring-1 ring-white/10">
      <%= render partial: 'helpers/errors' %>
      <%= form_for :user, html: { novalidate: true } do |f| %>
        <div class="mt-2">
          <%= f.label :email, t('.email'), for: "email", class: "block text-sm font-medium leading-6 text-gray-200" %>
          <div class="mt-2">
            <%= f.email_field :email, type: "email", autocomplete: "email", required: true,
                              value: flash[:register_params]&.dig('email'),
                              class: "block w-full rounded-md border-0 py-1.5 bg-gray-700 text-white shadow-sm ring-1
                                     ring-inset ring-white/10 placeholder:text-gray-500 focus:ring-2 focus:ring-inset
                                     focus:ring-indigo-500 sm:text-sm sm:leading-6" %>
          </div>
        </div>

        <div class="mt-4">
          <%= f.label :name, t('.nickname'), for: "login", class: "block text-sm font-medium leading-6 text-gray-200" %>
          <div class="mt-2">
            <%= f.text_field :name, required: true, autocomplete: "name",
                             value: flash[:register_params]&.dig('name'),
                             class: "block w-full rounded-md border-0 py-1.5 bg-gray-700 text-white shadow-sm ring-1
                                    ring-inset ring-white/10 placeholder:text-gray-500 focus:ring-2 focus:ring-inset
                                    focus:ring-indigo-500 sm:text-sm sm:leading-6" %>
          </div>
        </div>

        <div class="mt-4">
          <%= f.label :password, t('.password'),
                      class: "block text-sm font-medium leading-6 text-gray-200" %>
          <div class="mt-2">
            <%= f.password_field :password, autocomplete: "new-password", required: true,
                                 class: "block w-full rounded-md border-0 py-1.5 bg-gray-700 text-white shadow-sm ring-1
                                        ring-inset ring-white/10 placeholder:text-gray-500 focus:ring-2 focus:ring-inset
                                        focus:ring-indigo-500 sm:text-sm sm:leading-6" %>
          </div>
        </div>

        <div class="mt-4">
          <%= f.label :password_confirmation, t('.confirm'),
                      class: "block text-sm font-medium leading-6 text-gray-200" %>
          <div class="mt-2">
            <%= f.password_field :password_confirmation, autocomplete: "new-password", required: true,
                                 class: "block w-full rounded-md border-0 py-1.5 bg-gray-700 text-white shadow-sm ring-1
                                        ring-inset ring-white/10 placeholder:text-gray-500 focus:ring-2 focus:ring-inset
                                        focus:ring-indigo-500 sm:text-sm sm:leading-6" %>
          </div>
        </div>

        <div class="mt-6">
          <%= submit_tag t('.btn'), class: "flex w-full justify-center rounded-md bg-indigo-600 px-3 py-1.5
                  text-sm font-semibold leading-6 text-white shadow-sm hover:bg-indigo-500
                  focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2
                  focus-visible:outline-indigo-600 cursor-pointer" %>
        </div>
      <% end %>

    </div>

    <p class="mt-10 text-center text-sm text-gray-400">
      <%= t '.hint' %>
      <%= link_to login_path, class: "font-semibold leading-6 text-indigo-400 hover:text-indigo-300" do %>
        <%= t('.sign_in') %>
        <span aria-hidden="true">&rarr;</span>
      <% end %>
    </p>
  </div>
</div>
