<div class="py-4">
  <% earned_keys = user_achievements.map(&:achievement_key).to_set %>
  <% if earned_keys.any? %>
    <div class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-6 lg:grid-cols-8 gap-4">
      <% AchievementService::ACHIEVEMENTS.each do |key, config| %>
        <% next unless earned_keys.include?(key) %>
        <% ua = user_achievements.find { |a| a.achievement_key == key } %>
        <div class="flex flex-col items-center gap-1 group relative"
             title="<%= t "achievements.#{key}.name" %> — <%= t "achievements.#{key}.description" %>">
          <div class="relative">
            <%= image_tag "achievements/#{key}.svg", alt: t("achievements.#{key}.name"),
                class: "h-14 w-14 drop-shadow-md transition-transform group-hover:scale-110" %>
          </div>
          <span class="text-center text-xs font-medium text-gray-700 leading-tight">
            <%= t "achievements.#{key}.name" %>
          </span>
          <span class="text-xs text-gray-400">
            <%= ua.earned_at.strftime('%m.%Y') %>
          </span>
          <div class="pointer-events-none absolute bottom-full mb-2 left-1/2 -translate-x-1/2 z-10
                      w-44 rounded-lg bg-gray-900 px-3 py-2 text-xs text-white opacity-0
                      group-hover:opacity-100 transition-opacity shadow-lg">
            <p class="font-semibold mb-1"><%= t "achievements.#{key}.name" %></p>
            <p class="text-gray-300"><%= t "achievements.#{key}.description" %></p>
            <div class="mt-1">
              <% tier_label, tier_classes = case config[:tier]
                 when :bronze then [t('achievements.tiers.bronze'), 'bg-amber-100 text-amber-800']
                 when :silver then [t('achievements.tiers.silver'), 'bg-gray-100 text-gray-700']
                 when :gold   then [t('achievements.tiers.gold'),   'bg-yellow-100 text-yellow-800']
                 when :special then [t('achievements.tiers.special'), 'bg-purple-100 text-purple-800']
                 end %>
              <span class="inline-block rounded-full px-2 py-0.5 text-xs font-medium <%= tier_classes %>">
                <%= tier_label %>
              </span>
            </div>
            <div class="absolute top-full left-1/2 -translate-x-1/2 border-4 border-transparent border-t-gray-900"></div>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="text-center py-10">
      <svg class="mx-auto h-10 w-10 text-gray-300" fill="none" viewBox="0 0 24 24" stroke-width="1" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 18.75h-9m9 0a3 3 0 0 1 3 3h-15a3 3 0 0 1 3-3m9 0v-3.375c0-.621-.503-1.125-1.125-1.125h-.871M7.5 18.75v-3.375c0-.621.504-1.125 1.125-1.125h.872m5.007 0H9.497m5.007 0a7.454 7.454 0 0 1-.982-3.172M9.497 14.25a7.454 7.454 0 0 0 .981-3.172M5.25 4.236c-.982.143-1.954.317-2.916.52A6.003 6.003 0 0 0 7.73 9.728M5.25 4.236V4.5c0 2.108.966 3.99 2.48 5.228M5.25 4.236V2.721C7.456 2.41 9.71 2.25 12 2.25c2.291 0 4.545.16 6.75.47v1.516M7.73 9.728a6.726 6.726 0 0 0 2.748 1.35m8.272-6.842V4.5c0 2.108-.966 3.99-2.48 5.228m2.48-5.492a46.32 46.32 0 0 1 2.916.52 6.003 6.003 0 0 1-5.395 4.972m0 0a6.726 6.726 0 0 1-2.749 1.35m0 0a6.772 6.772 0 0 1-3.044 0"/>
      </svg>
      <p class="mt-2 text-sm text-gray-500"><%= t 'achievements.none_earned' %></p>
    </div>
  <% end %>
</div>
