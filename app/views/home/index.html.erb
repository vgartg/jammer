<div class="bg-gray-900">

  <%# Hero %>
  <div class="relative isolate overflow-hidden pb-16 pt-14 sm:pb-20">
    <div class="absolute inset-x-0 -top-40 -z-10 transform-gpu overflow-hidden blur-3xl sm:-top-80" aria-hidden="true">
      <div class="relative left-[calc(50%-11rem)] aspect-[1155/678] w-[36.125rem] -translate-x-1/2 rotate-[30deg] bg-gradient-to-tr from-[#ff80b5] to-[#9089fc] opacity-20 sm:left-[calc(50%-30rem)] sm:w-[72.1875rem]"
           style="clip-path: polygon(74.1% 44.1%, 100% 61.6%, 97.5% 26.9%, 85.5% 0.1%, 80.7% 2%, 72.5% 32.5%, 60.2% 62.4%, 52.4% 68.1%, 47.5% 58.3%, 45.2% 34.5%, 27.5% 76.7%, 0.1% 64.9%, 17.9% 100%, 27.6% 76.8%, 76.1% 97.7%, 74.1% 44.1%)"></div>
    </div>

    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mx-auto max-w-2xl py-20 sm:py-28 lg:py-36 text-center">
        <% unless @current_user %>
          <div class="mb-8 flex justify-center">
            <div class="relative rounded-full px-3 py-1 text-sm leading-6 text-gray-400 ring-1 ring-white/10 hover:ring-white/20">
              <%= t 'layouts.header.sign_up' %>
              <a href="<%= register_path %>" class="font-semibold text-white">
                <span class="absolute inset-0" aria-hidden="true"></span>
                <%= t 'home.read_mode' %> <span aria-hidden="true">&rarr;</span>
              </a>
            </div>
          </div>
        <% end %>
        <h1 class="text-4xl font-bold tracking-tight text-white sm:text-6xl">
          <%= t 'home.title' %>
        </h1>
        <p class="mt-6 text-lg leading-8 text-gray-300">
          <%= t 'home.description' %>
        </p>
        <div class="mt-10 flex items-center justify-center gap-x-6">
          <% if @current_user %>
            <%= link_to t('home.cta_explore'), jams_showcase_path,
                class: "rounded-md bg-indigo-600 px-5 py-3 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600 transition-colors" %>
          <% else %>
            <%= link_to t('home.cta_join'), register_path,
                class: "rounded-md bg-indigo-600 px-5 py-3 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600 transition-colors" %>
            <%= link_to t('home.cta_explore'), jams_showcase_path,
                class: "text-sm font-semibold leading-6 text-white" do %>
              <%= t 'home.cta_explore' %> <span aria-hidden="true">→</span>
            <% end %>
          <% end %>
        </div>
      </div>
    </div>

    <div class="absolute inset-x-0 top-[calc(100%-13rem)] -z-10 transform-gpu overflow-hidden blur-3xl sm:top-[calc(100%-30rem)]" aria-hidden="true">
      <div class="relative left-[calc(50%+3rem)] aspect-[1155/678] w-[36.125rem] -translate-x-1/2 bg-gradient-to-tr from-[#ff80b5] to-[#9089fc] opacity-20 sm:left-[calc(50%+36rem)] sm:w-[72.1875rem]"
           style="clip-path: polygon(74.1% 44.1%, 100% 61.6%, 97.5% 26.9%, 85.5% 0.1%, 80.7% 2%, 72.5% 32.5%, 60.2% 62.4%, 52.4% 68.1%, 47.5% 58.3%, 45.2% 34.5%, 27.5% 76.7%, 0.1% 64.9%, 17.9% 100%, 27.6% 76.8%, 76.1% 97.7%, 74.1% 44.1%)"></div>
    </div>
  </div>

  <%# Stats %>
  <div class="border-t border-white/10">
    <div class="mx-auto max-w-7xl px-6 py-16 lg:px-8">
      <dl class="grid grid-cols-1 gap-x-8 gap-y-10 sm:grid-cols-3 text-center">
        <div class="mx-auto flex max-w-xs flex-col gap-y-2">
          <dt class="text-sm leading-7 text-gray-400"><%= t 'home.stats_jams' %></dt>
          <dd class="order-first text-4xl font-bold tracking-tight text-white"><%= @stats[:jams] %></dd>
        </div>
        <div class="mx-auto flex max-w-xs flex-col gap-y-2">
          <dt class="text-sm leading-7 text-gray-400"><%= t 'home.stats_games' %></dt>
          <dd class="order-first text-4xl font-bold tracking-tight text-white"><%= @stats[:games] %></dd>
        </div>
        <div class="mx-auto flex max-w-xs flex-col gap-y-2">
          <dt class="text-sm leading-7 text-gray-400"><%= t 'home.stats_users' %></dt>
          <dd class="order-first text-4xl font-bold tracking-tight text-white"><%= @stats[:users] %></dd>
        </div>
      </dl>
    </div>
  </div>

  <%# Recent jams %>
  <div class="border-t border-white/10">
    <div class="mx-auto max-w-7xl px-6 py-16 lg:px-8">
      <div class="flex items-center justify-between mb-8">
        <h2 class="text-2xl font-bold tracking-tight text-white"><%= t 'home.jams_section' %></h2>
        <%= link_to t('home.cta_explore'), jams_showcase_path,
            class: "text-sm font-semibold text-indigo-400 hover:text-indigo-300 transition-colors" %>
      </div>
      <% if @recent_jams.any? %>
        <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
          <% @recent_jams.each do |jam| %>
            <a href="<%= jam_profile_path(jam) %>" class="group relative flex flex-col overflow-hidden rounded-xl bg-gray-800 ring-1 ring-white/10 hover:ring-indigo-500/50 transition-all">
              <div class="relative h-40 overflow-hidden bg-gray-700">
                <% if jam.cover.attached? %>
                  <%= image_tag url_for(jam.cover), alt: jam.name, class: "h-full w-full object-cover group-hover:opacity-80 transition-opacity" %>
                <% else %>
                  <div class="flex h-full items-center justify-center">
                    <svg class="h-10 w-10 text-gray-600" fill="none" viewBox="0 0 24 24" stroke-width="1" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" d="m2.25 15.75 5.159-5.159a2.25 2.25 0 0 1 3.182 0l5.159 5.159m-1.5-1.5 1.409-1.409a2.25 2.25 0 0 1 3.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 0 0 1.5-1.5V6a1.5 1.5 0 0 0-1.5-1.5H3.75A1.5 1.5 0 0 0 2.25 6v12a1.5 1.5 0 0 0 1.5 1.5Zm10.5-11.25h.008v.008h-.008V8.25Zm.375 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Z" />
                    </svg>
                  </div>
                <% end %>
                <%# Status badge %>
                <div class="absolute top-2 left-2">
                  <% if jam.submission_open? %>
                    <span class="inline-flex items-center rounded-full bg-green-900/80 px-2.5 py-0.5 text-xs font-medium text-green-300 ring-1 ring-green-500/30">
                      <%= t 'home.jam_active' %>
                    </span>
                  <% elsif jam.voting_open? %>
                    <span class="inline-flex items-center rounded-full bg-amber-900/80 px-2.5 py-0.5 text-xs font-medium text-amber-300 ring-1 ring-amber-500/30">
                      <%= t 'home.jam_voting' %>
                    </span>
                  <% elsif jam.start_date.present? && jam.start_date > Date.today %>
                    <span class="inline-flex items-center rounded-full bg-indigo-900/80 px-2.5 py-0.5 text-xs font-medium text-indigo-300 ring-1 ring-indigo-500/30">
                      <%= t 'home.jam_upcoming' %>
                    </span>
                  <% else %>
                    <span class="inline-flex items-center rounded-full bg-gray-700/80 px-2.5 py-0.5 text-xs font-medium text-gray-400 ring-1 ring-gray-500/30">
                      <%= t 'home.jam_finished' %>
                    </span>
                  <% end %>
                </div>
              </div>
              <div class="flex flex-1 flex-col p-4">
                <h3 class="text-sm font-semibold text-white group-hover:text-indigo-300 transition-colors truncate"><%= jam.name %></h3>
                <% if jam.start_date.present? && jam.deadline.present? %>
                  <p class="mt-1 text-xs text-gray-400">
                    <%= jam.start_date.strftime('%d.%m.%Y') %> – <%= jam.deadline.strftime('%d.%m.%Y') %>
                  </p>
                <% end %>
                <% if jam.tags.any? %>
                  <div class="mt-2 flex flex-wrap gap-1">
                    <% jam.tags.first(3).each do |tag| %>
                      <span class="rounded-full bg-gray-700 px-2 py-0.5 text-xs text-gray-300"><%= tag.name %></span>
                    <% end %>
                  </div>
                <% end %>
              </div>
            </a>
          <% end %>
        </div>
      <% else %>
        <p class="text-gray-400 text-sm"><%= t 'home.no_jams' %></p>
      <% end %>
    </div>
  </div>

  <%# Features %>
  <div class="border-t border-white/10">
    <div class="mx-auto max-w-7xl px-6 py-16 lg:px-8">
      <h2 class="text-2xl font-bold tracking-tight text-white text-center mb-12"><%= t 'home.features_title' %></h2>
      <dl class="grid max-w-xl grid-cols-1 gap-x-8 gap-y-10 lg:max-w-none lg:grid-cols-3">
        <div class="relative pl-16">
          <dt class="text-base font-semibold leading-7 text-white">
            <div class="absolute left-0 top-0 flex h-10 w-10 items-center justify-center rounded-lg bg-indigo-600">
              <svg class="h-6 w-6 text-white" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5" />
              </svg>
            </div>
            <%= t 'home.feature_1_title' %>
          </dt>
          <dd class="mt-2 text-base leading-7 text-gray-400"><%= t 'home.feature_1_desc' %></dd>
        </div>
        <div class="relative pl-16">
          <dt class="text-base font-semibold leading-7 text-white">
            <div class="absolute left-0 top-0 flex h-10 w-10 items-center justify-center rounded-lg bg-indigo-600">
              <svg class="h-6 w-6 text-white" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 16.5V9.75m0 0 3 3m-3-3-3 3M6.75 19.5a4.5 4.5 0 0 1-1.41-8.775 5.25 5.25 0 0 1 10.233-2.33 3 3 0 0 1 3.758 3.848A3.752 3.752 0 0 1 18 19.5H6.75Z" />
              </svg>
            </div>
            <%= t 'home.feature_2_title' %>
          </dt>
          <dd class="mt-2 text-base leading-7 text-gray-400"><%= t 'home.feature_2_desc' %></dd>
        </div>
        <div class="relative pl-16">
          <dt class="text-base font-semibold leading-7 text-white">
            <div class="absolute left-0 top-0 flex h-10 w-10 items-center justify-center rounded-lg bg-indigo-600">
              <svg class="h-6 w-6 text-white" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 0 1 1.04 0l2.125 5.111a.563.563 0 0 0 .475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 0 0-.182.557l1.285 5.385a.562.562 0 0 1-.84.61l-4.725-2.885a.562.562 0 0 0-.586 0L6.982 20.54a.562.562 0 0 1-.84-.61l1.285-5.386a.562.562 0 0 0-.182-.557l-4.204-3.602a.562.562 0 0 1 .321-.988l5.518-.442a.563.563 0 0 0 .475-.345L11.48 3.5Z" />
              </svg>
            </div>
            <%= t 'home.feature_3_title' %>
          </dt>
          <dd class="mt-2 text-base leading-7 text-gray-400"><%= t 'home.feature_3_desc' %></dd>
        </div>
      </dl>
    </div>
  </div>

  <%# CTA bottom %>
  <% unless @current_user %>
    <div class="border-t border-white/10">
      <div class="mx-auto max-w-7xl px-6 py-16 lg:px-8 text-center">
        <h2 class="text-2xl font-bold tracking-tight text-white sm:text-3xl mb-4">
          <%= t 'home.cta_join' %>
        </h2>
        <p class="text-gray-400 mb-8"><%= t 'home.description' %></p>
        <%= link_to t('home.cta_join'), register_path,
            class: "rounded-md bg-indigo-600 px-6 py-3 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 transition-colors" %>
      </div>
    </div>
  <% end %>

</div>
