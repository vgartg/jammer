<div class="bg-gray-900 min-h-screen">

  <%# Hero %>
  <div class="relative isolate overflow-hidden px-6 py-24 sm:py-32 lg:px-8 text-center">
    <div class="absolute inset-x-0 -top-40 -z-10 transform-gpu overflow-hidden blur-3xl sm:-top-80" aria-hidden="true">
      <div class="relative left-[calc(50%-11rem)] aspect-[1155/678] w-[36.125rem] -translate-x-1/2 rotate-[30deg] bg-gradient-to-tr from-[#ff80b5] to-[#9089fc] opacity-20 sm:left-[calc(50%-30rem)] sm:w-[72.1875rem]"
           style="clip-path: polygon(74.1% 44.1%, 100% 61.6%, 97.5% 26.9%, 85.5% 0.1%, 80.7% 2%, 72.5% 32.5%, 60.2% 62.4%, 52.4% 68.1%, 47.5% 58.3%, 45.2% 34.5%, 27.5% 76.7%, 0.1% 64.9%, 17.9% 100%, 27.6% 76.8%, 76.1% 97.7%, 74.1% 44.1%)"></div>
    </div>
    <div class="mx-auto max-w-2xl">
      <h1 class="text-4xl font-bold tracking-tight text-white sm:text-6xl"><%= t 'home.title' %></h1>
      <p class="mt-4 text-lg text-gray-300"><%= t 'home.description' %></p>
      <div class="mt-8 flex items-center justify-center gap-4">
        <%= link_to t('home.cta_explore'), jams_showcase_path,
            class: "rounded-md bg-indigo-600 px-5 py-2.5 text-sm font-semibold text-white hover:bg-indigo-500 transition-colors" %>
        <% unless @current_user %>
          <%= link_to t('home.cta_join'), register_path,
              class: "text-sm font-semibold text-gray-300 hover:text-white transition-colors" %>
        <% end %>
      </div>
    </div>
  </div>

  <%# Recent jams %>
  <% if @recent_jams.any? %>
    <div class="mx-auto max-w-7xl px-6 pb-24 lg:px-8">
      <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
        <% @recent_jams.each do |jam| %>
          <a href="<%= jam_profile_path(jam) %>" class="group relative flex flex-col overflow-hidden rounded-xl bg-gray-800 ring-1 ring-white/10 hover:ring-indigo-500/50 transition-all">
            <div class="relative h-36 overflow-hidden bg-gray-700">
              <% if jam.cover.attached? %>
                <%= image_tag url_for(jam.cover), alt: jam.name, class: "h-full w-full object-cover group-hover:opacity-80 transition-opacity" %>
              <% else %>
                <div class="flex h-full items-center justify-center">
                  <svg class="h-8 w-8 text-gray-600" fill="none" viewBox="0 0 24 24" stroke-width="1" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="m2.25 15.75 5.159-5.159a2.25 2.25 0 0 1 3.182 0l5.159 5.159m-1.5-1.5 1.409-1.409a2.25 2.25 0 0 1 3.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 0 0 1.5-1.5V6a1.5 1.5 0 0 0-1.5-1.5H3.75A1.5 1.5 0 0 0 2.25 6v12a1.5 1.5 0 0 0 1.5 1.5Z" />
                  </svg>
                </div>
              <% end %>
              <% if jam.submission_open? %>
                <span class="absolute top-2 left-2 rounded-full bg-green-900/80 px-2 py-0.5 text-xs font-medium text-green-300"><%= t 'home.jam_active' %></span>
              <% elsif jam.voting_open? %>
                <span class="absolute top-2 left-2 rounded-full bg-amber-900/80 px-2 py-0.5 text-xs font-medium text-amber-300"><%= t 'home.jam_voting' %></span>
              <% elsif jam.start_date.present? && jam.start_date > Date.today %>
                <span class="absolute top-2 left-2 rounded-full bg-indigo-900/80 px-2 py-0.5 text-xs font-medium text-indigo-300"><%= t 'home.jam_upcoming' %></span>
              <% end %>
            </div>
            <div class="p-4">
              <h3 class="text-sm font-semibold text-white group-hover:text-indigo-300 transition-colors truncate"><%= jam.name %></h3>
              <% if jam.start_date.present? %>
                <p class="mt-1 text-xs text-gray-500"><%= jam.start_date.strftime('%d.%m.%Y') %> – <%= jam.deadline.strftime('%d.%m.%Y') %></p>
              <% end %>
            </div>
          </a>
        <% end %>
      </div>
    </div>
  <% end %>

</div>
